          "coursePrerequisites":"Domini de pull-up estricte i handstand hold",
          "hasCourseInstance":{"@type":"CourseInstance","courseMode":"Onsite","location":{"@id":"https://crossfitlamola.com/#organization"}}
        }},
        {"@type":"ListItem","position":6,"item":{"@id":"https://crossfitlamola.com/classes#hybrid","url":"https://crossfitlamola.com/classes#hybrid","image":"https://crossfitlamola.com/assets/class-hybrid.webp",
          "@type":"Course","name":"Hybrid Club","description":"Entrenament híbrid amb sled push/pull, ergòmetres (rower, ski erg), wall balls, kettlebells i intervals de carrera. Format inspirat en competicions estil HYROX.",
          "provider":{"@id":"https://crossfitlamola.com/#organization"},
          "inLanguage":"ca","educationalLevel":"All Levels","timeRequired":"PT60M",
          "audience":{"@type":"EducationalAudience","audienceType":"Persones que volen combinar resistència i força funcional amb formats híbrids tipus competicions com HYROX"},
