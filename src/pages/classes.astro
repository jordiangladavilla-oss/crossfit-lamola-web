        }},
        {"@type":"ListItem","position":2,"item":{"@id":"https://crossfitlamola.com/classes#weightlifting","url":"https://crossfitlamola.com/classes#weightlifting","image":"https://crossfitlamola.com/assets/class-weightlifting.webp",
