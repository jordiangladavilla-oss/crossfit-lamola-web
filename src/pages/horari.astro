---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<Layout
  title="Horari setmanal · CrossFit La Mola Terrassa"
  description="Horari setmanal del box de CrossFit a Terrassa. Classes de dilluns a diumenge: WOD, halterofilia, hybrid, strength i mes. Reserva per l'app Aimharder."
  canonical="https://crossfitlamola.com/horari"
>
  <Nav currentPage="/horari" />

  <section class="page-hero">
    <div class="bg" style="background-image:url('/assets/community-5.jpg')"></div>
    <div class="inner">
      <div class="crumb"><a href="/">Inici</a><span>/</span><span>Horari</span></div>
      <div class="kicker"><span>Setmanal</span><span class="bar"></span><span>Reserva via Aimharder</span></div>
      <h1>L'horari<br>de la <em class="serif">setmana</em><span class="dot">.</span></h1>
      <p class="sub">Dilluns a divendres de 07:00 a 21:30. Dissabte i diumenge de 09:30 a 11:30 amb activitats especials. Reserva per l'app. La primera classe sempre es gratis.</p>
    </div>
  </section>

  <div class="status-strip">
    <div class="wrap">
      <span id="status"><span class="dot-live" id="statusDot"></span><span id="statusText">Obert ara</span></span>
      <span>Av. del Valles 724C · Terrassa</span>
      <span>Dl-Dv 07:00-21:30 · Ds 09:30-11:30 · Dg 09:30-11:30</span>
      <span style="margin-left:auto;"><a href="https://wa.me/34629066531" style="color:var(--accent-ink);">WhatsApp &rarr;</a></span>
    </div>
  </div>

  <section class="sec bone" style="padding-top:clamp(64px,8vw,120px);">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">01 —</span><span>Graella setmanal</span></div>
      <div style="height:16px"></div>
      <div class="sec-head">
        <h2 class="h-xl reveal">Totes les<br>classes, <em class="serif">totes</em> les franges<span class="dot">.</span></h2>
        <p class="lead reveal">Filtra per disciplina. Les classes amb coach tenen capacitat limitada. Reserva amb antelacio especialment a les franges de mati i de vespre.</p>
      </div>

      <div class="toggle-row reveal">
        <label><input type="checkbox" id="showOpen"> Mostrar Open Gym i Open Exterior</label>
        <span style="opacity:.7;">Per defecte nomes veus classes amb coach</span>
      </div>

      <div class="filters reveal" id="filters">
        <button class="filter on" data-f="all">Totes <span class="count" id="c-all"></span></button>
        <button class="filter" data-f="wod">WOD <span class="count" id="c-wod"></span></button>
        <button class="filter" data-f="wl">Weightlifting <span class="count" id="c-wl"></span></button>
        <button class="filter" data-f="hy">Hybrid <span class="count" id="c-hy"></span></button>
        <button class="filter" data-f="bw">Bodyweight <span class="count" id="c-bw"></span></button>
        <button class="filter" data-f="st">Strength <span class="count" id="c-st"></span></button>
        <button class="filter" data-f="ab">Abs &amp; Cals <span class="count" id="c-ab"></span></button>
        <button class="filter" data-f="pr">The Program <span class="count" id="c-pr"></span></button>
        <button class="filter" data-f="rc">Running <span class="count" id="c-rc"></span></button>
        <button class="filter" data-f="etc">Entrena amb coach <span class="count" id="c-etc"></span></button>
      </div>

      <div class="week reveal" id="week">
        <div class="loading" style="grid-column:1/-1;text-align:center;padding:60px 20px;font-family:var(--f-mono);font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted-ink);">Carregant horari...</div>
      </div>

      <div class="legend reveal">
        <span class="chip" style="--c:var(--bone-ink);">WOD</span>
        <span class="chip" style="--c:var(--accent-ink);">Weightlifting · Program</span>
        <span class="chip" style="--c:#3d5f3f;">Hybrid</span>
        <span class="chip" style="--c:#8c3f2f;">Strength</span>
        <span class="chip" style="--c:#5a4a2f;">Bodyweight</span>
        <span class="chip" style="--c:#7a4a3a;">Abs &amp; Cals</span>
        <span class="chip" style="--c:#3a5a7a;">Running</span>
      </div>

      <div class="meta-card reveal">
        <strong>Com reservar:</strong> Descarrega l'app <strong>Aimharder</strong> i registra't amb el teu codi. Pots reservar <strong>des de 24h abans</strong>. Si has consumit la teva quota mensual, pots fer <strong>classes extres a 6eur/classe</strong> o pujar de tarifa.
      </div>
    </div>
  </section>

  <section class="cta-block">
    <div class="bg" style="background-image:url('/assets/class-program.jpg')"></div>
    <div class="inner">
      <div class="eyebrow reveal" style="color:var(--bone-3)"><span class="num" style="color:var(--accent-hi)">02 —</span><span>Primera vegada?</span></div>
      <h2 class="h-hero reveal">Reserva<br>la teva <em class="serif">primera</em><span class="dot">.</span></h2>
      <p class="reveal">Si es el teu primer cop, escriu-nos abans i et preparem una benvinguda adaptada al teu nivell.</p>
      <div class="actions reveal">
        <a class="btn-primary" href="/contacte">Reservar primera classe<span class="arr"></span></a>
        <a class="btn-ghost" href="/classes">Veure disciplines</a>
      </div>
    </div>
  </section>

  <Footer />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ExerciseGym",
    "@id": "https://crossfitlamola.com/#organization",
    "name": "CrossFit La Mola",
    "alternateName": "La Mola CrossFit",
    "description": "Box de CrossFit a Terrassa des de 2025. Entrenament funcional, halterofilia, gimnastic i cardio amb coaches certificats CF-L1 i CF-L2.",
    "url": "https://crossfitlamola.com/",
    "logo": "https://crossfitlamola.com/assets/logo-full.png",
    "image": "https://crossfitlamola.com/assets/hero-still.jpg",
    "telephone": "+34629066531",
    "email": "info@crossfitlamola.com",
    "priceRange": "EUR EUR",
    "foundingDate": "2025",
    "currenciesAccepted": "EUR",
    "paymentAccepted": "Credit Card, Bank Transfer, Direct Debit, Virtual POS",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Avinguda del Valles 724 C",
      "postalCode": "08227",
      "addressLocality": "Terrassa",
      "addressRegion": "Catalunya",
      "addressCountry": "ES"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "41.581285", "longitude": "2.027955" },
    "hasMap": "https://maps.app.goo.gl/LMWX4XfiVLq8PXxAA",
    "sameAs": [
      "https://www.instagram.com/lamolacrossfit/",
      "https://share.google/pTO0bMKcTnShi6oAO"
    ],
    "openingHoursSpecification": [
      {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"07:00","closes":"21:30"},
      {"@type":"OpeningHoursSpecification","dayOfWeek":["Saturday","Sunday"],"opens":"09:30","closes":"11:30"}
    ],
    "areaServed": [
      {"@type":"City","name":"Terrassa"},
      {"@type":"City","name":"Sabadell"},
      {"@type":"City","name":"Sant Cugat del Valles"},
      {"@type":"City","name":"Rubi"},
      {"@type":"AdministrativeArea","name":"Valles Occidental"}
    ]
  }
  </script>

  <style>
    .status-strip{ padding:18px var(--page-pad); background:var(--bone-soft); color:var(--bone-ink); border-bottom:1px solid var(--line-ink);}
    .status-strip .wrap{ max-width:var(--max); margin:0 auto; display:flex; flex-wrap:wrap; gap:20px 32px; align-items:center; font-family:var(--f-mono); font-size:11px; letter-spacing:.2em; text-transform:uppercase;}
    .status-strip .dot-live{ width:8px; height:8px; background:#2f8f3f; border-radius:50%; display:inline-block; margin-right:10px; box-shadow:0 0 0 4px rgba(47,143,63,.15);}
    .status-strip .dot-live.closed{ background:#b85a3a; box-shadow:0 0 0 4px rgba(184,90,58,.15);}

    /* Filter chips */
    .filters{ display:flex; flex-wrap:wrap; gap:8px; margin:40px 0 32px;}
    .filter{ font-family:var(--f-mono); font-size:10.5px; letter-spacing:.2em; text-transform:uppercase; padding:10px 16px 9px; border:1px solid var(--line-ink-s); border-radius:999px; color:var(--bone-ink); opacity:.7; cursor:pointer; transition:all .2s; background:transparent;}
    .filter:hover{ opacity:1;}
    .filter.on{ background:var(--bone-ink); color:var(--bone); border-color:var(--bone-ink); opacity:1;}
    .filter .count{ margin-left:6px; opacity:.6;}

    /* Toggle open-gym */
    .toggle-row{ display:flex; flex-wrap:wrap; gap:24px; align-items:center; margin-bottom:28px; font-family:var(--f-mono); font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--muted-ink);}
    .toggle-row label{ display:inline-flex; align-items:center; gap:10px; cursor:pointer;}
    .toggle-row input{ appearance:none; width:32px; height:18px; background:var(--line-ink-s); border-radius:999px; position:relative; transition:background .2s; cursor:pointer;}
    .toggle-row input::after{ content:""; position:absolute; top:2px; left:2px; width:14px; height:14px; background:var(--bone); border-radius:50%; transition:transform .2s; box-shadow:0 1px 2px rgba(0,0,0,.2);}
    .toggle-row input:checked{ background:var(--accent-ink);}
    .toggle-row input:checked::after{ transform:translateX(14px);}

    /* Day accordion (mobile) + grid (desktop) */
    .week{ display:grid; grid-template-columns:1fr; gap:40px; margin-top:20px;}
    @media(min-width:1100px){ .week{ grid-template-columns:repeat(7,1fr); gap:1px; background:var(--line-ink); border:1px solid var(--line-ink); border-radius:2px; overflow:hidden;} }

    /* mobile day blocks */
    .day{ background:var(--bone); padding:24px 16px;}
    @media(min-width:1100px){
      .day{ padding:14px 10px 20px;}
    }
    .day h4{ font-family:var(--f-display); font-weight:500; font-size:20px; letter-spacing:-0.02em; margin:0 0 2px; display:flex; align-items:baseline; gap:8px;}
    .day h4 .abbrev{ display:none;}
    @media(min-width:1100px){ .day h4 .full{ display:none;} .day h4 .abbrev{ display:inline;} }
    .day .date{ display:none; }
    .day.today h4{ color:var(--accent-ink);}
    .day.today h4::after{ content:"· avui"; font-family:var(--f-serif); font-style:italic; font-size:14px; font-weight:400; margin-left:4px; letter-spacing:normal; text-transform:none; color:var(--accent-ink);}
    @media(min-width:1100px){ .day.today{ background:var(--bone-soft);} .day.today h4::after{ content:"· hoy"; display:inline;} }

    /* slot inside day */
    .slot{ padding:10px 0; border-top:1px solid var(--line-ink); transition:background .15s; cursor:default; position:relative;}
    .slot:last-child{ border-bottom:1px solid var(--line-ink);}
    .slot.hidden{ display:none;}
    .slot .time{ font-family:var(--f-mono); font-size:11px; letter-spacing:.12em; color:var(--bone-ink); font-weight:500;}
    .slot .disc{ font-family:var(--f-display); font-weight:500; font-size:14px; letter-spacing:-0.005em; margin-top:3px; line-height:1.2;}
    .slot .extras{ font-family:var(--f-mono); font-size:9.5px; letter-spacing:.15em; text-transform:uppercase; color:var(--muted-ink); margin-top:4px; opacity:.7;}
    .slot.open-only{ opacity:.45;}
    .slot.open-only.always-visible{ opacity:1;}
    .slot.open-only .disc{ font-weight:300; font-style:italic; font-family:var(--f-display);}
    .slot.open-only.always-visible .disc{ font-style:normal; font-weight:500; color:var(--bone-ink);}

    /* Discipline color tags */
    .slot[data-disc*="wod"] .disc{ color:var(--bone-ink);}
    .slot[data-disc*="wl"] .disc{ color:var(--accent-ink);}
    .slot[data-disc*="hy"] .disc{ color:#3d5f3f;}
    .slot[data-disc*="st"] .disc{ color:#8c3f2f;}
    .slot[data-disc*="bw"] .disc{ color:#5a4a2f;}
    .slot[data-disc*="ab"] .disc{ color:#7a4a3a;}
    .slot[data-disc*="pr"] .disc{ color:var(--accent-ink); font-weight:500;}
    .slot[data-disc*="rc"] .disc{ color:#3a5a7a;}
    .slot[data-disc*="pr"]{ background:linear-gradient(to right, rgba(185,169,114,.1), transparent 60%); }

    /* time column (desktop only) */
    .time-col{ display:none;}
    @media(min-width:1100px){
      .time-col{ display:block; background:var(--bone-soft); padding:60px 10px 20px; font-family:var(--f-mono); font-size:10px; letter-spacing:.15em; color:var(--muted-ink); text-transform:uppercase;}
      .time-col .row{ height:72px; border-top:1px dashed var(--line-ink); padding-top:6px; display:flex; align-items:flex-start;}
      .time-col .row:first-child{ border-top:none;}
    }

    .legend{ margin-top:48px; display:flex; flex-wrap:wrap; gap:16px 32px; padding-top:32px; border-top:1px solid var(--line-ink); font-family:var(--f-mono); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted-ink); align-items:center;}
    .legend span strong{ color:var(--bone-ink); font-weight:500;}
    .legend .chip{ display:inline-flex; align-items:center; gap:8px;}
    .legend .chip::before{ content:""; width:10px; height:10px; border-radius:2px; background:var(--c, var(--bone-ink));}

    .empty{ font-family:var(--f-serif); font-style:italic; font-size:14px; color:var(--muted-ink); padding:14px 0;}

    /* details inline panel */
    .meta-card{ background:var(--bone-soft); padding:20px 22px; margin:28px 0 0; border-left:2px solid var(--accent-ink); font-family:var(--f-serif); font-size:15.5px; line-height:1.55; color:var(--bone-ink);}
    .meta-card strong{ font-weight:500; letter-spacing:-0.005em;}
  </style>

  <script>
  const JSON_URL = 'https://raw.githubusercontent.com/jordiangladavilla-oss/lamola-tv-horari2026/master/horari.json';

  interface ClassItem {
    disc: string;
    label: string;
  }

  interface Slot {
    time: string;
    classes: ClassItem[];
  }

  interface Day {
    name: string;
    abbr: string;
    slots: Slot[];
  }

  interface HorariData {
    days: Day[];
  }

  function updateStatus() {
    const now = new Date();
    const d = now.getDay();
    const h = now.getHours() + now.getMinutes() / 60;
    const open = (d >= 1 && d <= 5 && h >= 7 && h < 21.5) || (d === 6 && h >= 9.5 && h < 11.5) || (d === 0 && h >= 9.5 && h < 11.5);
    const dot = document.getElementById('statusDot');
    const t = document.getElementById('statusText');
    if (dot && t) {
      if (open) { dot.classList.remove('closed'); t.textContent = 'Obert ara'; }
      else { dot.classList.add('closed'); t.textContent = 'Tancat ara'; }
    }
  }
  updateStatus();
  setInterval(updateStatus, 60000);

  async function loadSchedule() {
    try {
      const res = await fetch(JSON_URL);
      const data: HorariData = await res.json();
      renderSchedule(data);
    } catch (err) {
      console.error('Error carregant horari:', err);
      const week = document.getElementById('week');
      if (week) week.innerHTML = '<p class="empty" style="grid-column:1/-1;text-align:center;">Error carregant horari. Recarrega la pagina.</p>';
    }
  }

  function renderSchedule(data: HorariData) {
    const dayNames = ['Dilluns', 'Dimarts', 'Dimecres', 'Dijous', 'Divendres', 'Dissabte', 'Diumenge'];
    const abbrs = ['Dl', 'Dm', 'Dc', 'Dj', 'Dv', 'Ds', 'Dg'];

    const monday = new Date();
    const day = monday.getDay();
    const diff = (day === 0 ? -6 : 1 - day);
    monday.setDate(monday.getDate() + diff);
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const counts: Record<string, number> = { all: 0, wod: 0, wl: 0, hy: 0, bw: 0, st: 0, ab: 0, pr: 0, rc: 0, etc: 0 };
    const week = document.getElementById('week');
    if (!week) return;
    week.innerHTML = '';

    data.days.forEach((dayData, i) => {
      const d = new Date(monday);
      d.setDate(d.getDate() + i);
      const isToday = (d.getTime() === today.getTime());
      const div = document.createElement('div');
      div.className = 'day' + (isToday ? ' today' : '');
      div.innerHTML = '<h4><span class="full">' + dayData.name + '</span><span class="abbrev">' + dayData.abbr + '</span></h4>';

      const dayHasCoached = dayData.slots.some(slot => slot.classes.some(c => c.disc !== 'open'));

      if (!dayData.slots.length) {
        div.innerHTML += '<p class="empty">Descans · sense classes</p>';
      } else {
        dayData.slots.forEach(slot => {
          const coached = slot.classes.filter(c => c.disc !== 'open');
          const opens = slot.classes.filter(c => c.disc === 'open');

          if (!coached.length && !opens.length) return;

          if (coached.length) {
            coached.forEach(c => {
              counts.all++;
              if (counts[c.disc] !== undefined) counts[c.disc]++;
              let extras = '';
              if (opens.length) {
                const hasExterior = opens.some(o => o.label.toLowerCase().includes('exterior'));
                extras = '+ Open' + (hasExterior ? ' · Exterior' : '');
              }
              const el = document.createElement('div');
              el.className = 'slot';
              el.setAttribute('data-disc', c.disc);
              el.innerHTML = '<div class="time">' + slot.time + '</div><div class="disc">' + c.label + '</div>' + (extras ? '<div class="extras">' + extras + '</div>' : '');
              div.appendChild(el);
            });
          } else if (opens.length) {
            const label = opens.map(o => o.label.toLowerCase().includes('exterior') ? 'Open · Exterior' : 'Open Gym').join(' · ');
            const el = document.createElement('div');
            el.className = 'slot open-only' + (dayHasCoached ? '' : ' always-visible');
            el.setAttribute('data-disc', 'open');
            el.innerHTML = '<div class="time">' + slot.time + '</div><div class="disc">' + label + '</div>';
            div.appendChild(el);
          }
        });
      }
      week.appendChild(div);
    });

    Object.keys(counts).forEach(k => {
      const el = document.getElementById('c-' + k);
      if (el) el.textContent = '· ' + counts[k];
    });

    setupFilters();
  }

  function setupFilters() {
    let currentFilter = 'all';
    let showOpen = false;

    const filtersEl = document.getElementById('filters');
    if (filtersEl) {
      filtersEl.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const b = target.closest('.filter') as HTMLElement;
        if (!b) return;
        document.querySelectorAll('.filter').forEach(x => x.classList.remove('on'));
        b.classList.add('on');
        currentFilter = b.dataset.f || 'all';
        applyFilter();
      });
    }

    const showOpenEl = document.getElementById('showOpen') as HTMLInputElement;
    if (showOpenEl) {
      showOpenEl.addEventListener('change', (e) => {
        showOpen = (e.target as HTMLInputElement).checked;
        applyFilter();
      });
    }

    function applyFilter() {
      document.querySelectorAll('.slot').forEach(s => {
        const el = s as HTMLElement;
        const d = el.dataset.disc;
        const isOpen = (d === 'open');
        const alwaysVisible = el.classList.contains('always-visible');
        const matchFilter = (currentFilter === 'all') || (d === currentFilter);
        const visible = matchFilter && (!isOpen || showOpen || alwaysVisible);
        el.classList.toggle('hidden', !visible);
      });
    }
    applyFilter();
  }

  loadSchedule();
  </script>
</Layout>
