---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<Layout
  title="Horari setmanal · CrossFit La Mola Terrassa"
  description="Horari setmanal del box de CrossFit a Terrassa. Classes de dilluns a diumenge: WOD, halterofilia, hybrid, strength i mes. Reserva per l'app Aimharder."
  canonical="https://crossfitlamola.com/horari"
>
  <Nav currentPage="/horari" />

  <section class="page-hero">
    <div class="bg" style="background-image:url('/assets/community-5.jpg')"></div>
    <div class="inner">
      <div class="crumb"><a href="/">Inici</a><span>/</span><span>Horari</span></div>
      <div class="kicker"><span>Setmanal</span><span class="bar"></span><span>Reserva via Aimharder</span></div>
      <h1>L'horari<br>de la <em class="serif">setmana</em><span class="dot">.</span></h1>
      <p class="sub">Dilluns a divendres de 07:00 a 21:30. Dissabte i diumenge de 09:30 a 11:30 amb activitats especials. Reserva per l'app. La primera classe sempre es gratis.</p>
    </div>
  </section>

  <div class="status-strip">
    <div class="wrap">
      <span id="status"><span class="dot-live" id="statusDot"></span><span id="statusText">Obert ara</span></span>
      <span>Av. del Valles 724C · Terrassa</span>
      <span>Dl-Dv 07:00-21:30 · Ds 09:30-11:30 · Dg 09:30-11:30</span>
      <span style="margin-left:auto;"><a href="https://wa.me/34629066531" style="color:var(--accent-ink);">WhatsApp &rarr;</a></span>
    </div>
  </div>

  <section class="sec bone" style="padding-top:clamp(64px,8vw,120px);">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">01 —</span><span>Graella setmanal</span></div>
      <div style="height:16px"></div>
      <div class="sec-head">
        <h2 class="h-xl reveal">Totes les<br>classes, <em class="serif">totes</em> les franges<span class="dot">.</span></h2>
        <p class="lead reveal">Filtra per disciplina. Les classes amb coach tenen capacitat limitada. Reserva amb antelacio especialment a les franges de mati i de vespre.</p>
      </div>

      <div class="toggle-row reveal">
        <label><input type="checkbox" id="showOpen"> Mostrar Open Gym i Open Exterior</label>
        <span style="opacity:.7;">Per defecte nomes veus classes amb coach</span>
      </div>

      <div class="filters reveal" id="filters">
        <button class="filter on" data-f="all">Totes <span class="count" id="c-all"></span></button>
        <button class="filter" data-f="wod">WOD <span class="count" id="c-wod"></span></button>
        <button class="filter" data-f="wl">Weightlifting <span class="count" id="c-wl"></span></button>
        <button class="filter" data-f="hy">Hybrid <span class="count" id="c-hy"></span></button>
        <button class="filter" data-f="bw">Bodyweight <span class="count" id="c-bw"></span></button>
        <button class="filter" data-f="st">Strength <span class="count" id="c-st"></span></button>
        <button class="filter" data-f="ab">Abs &amp; Cals <span class="count" id="c-ab"></span></button>
        <button class="filter" data-f="pr">The Program <span class="count" id="c-pr"></span></button>
        <button class="filter" data-f="rc">Running <span class="count" id="c-rc"></span></button>
        <button class="filter" data-f="etc">Entrena amb coach <span class="count" id="c-etc"></span></button>
      </div>

      <div class="week reveal" id="week"></div>

      <div class="legend reveal">
        <span class="chip" style="--c:var(--bone-ink);">WOD</span>
        <span class="chip" style="--c:var(--accent-ink);">Weightlifting · Program</span>
        <span class="chip" style="--c:#3d5f3f;">Hybrid</span>
        <span class="chip" style="--c:#8c3f2f;">Strength</span>
        <span class="chip" style="--c:#5a4a2f;">Bodyweight</span>
        <span class="chip" style="--c:#7a4a3a;">Abs &amp; Cals</span>
        <span class="chip" style="--c:#3a5a7a;">Running</span>
      </div>

      <div class="meta-card reveal">
        <strong>Com reservar:</strong> Descarrega l'app <strong>Aimharder</strong> i registra't amb el teu codi. Pots reservar <strong>des de 24h abans</strong>. Si has consumit la teva quota mensual, pots fer <strong>classes extres a 6eur/classe</strong> o pujar de tarifa.
      </div>
    </div>
  </section>

  <section class="cta-block">
    <div class="bg" style="background-image:url('/assets/class-program.jpg')"></div>
    <div class="inner">
      <div class="eyebrow reveal" style="color:var(--bone-3)"><span class="num" style="color:var(--accent-hi)">02 —</span><span>Primera vegada?</span></div>
      <h2 class="h-hero reveal">Reserva<br>la teva <em class="serif">primera</em><span class="dot">.</span></h2>
      <p class="reveal">Si es el teu primer cop, escriu-nos abans i et preparem una benvinguda adaptada al teu nivell.</p>
      <div class="actions reveal">
        <a class="btn-primary" href="/contacte">Reservar primera classe<span class="arr"></span></a>
        <a class="btn-ghost" href="/classes">Veure disciplines</a>
      </div>
    </div>
  </section>

  <Footer />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ExerciseGym",
    "@id": "https://crossfitlamola.com/#organization",
    "name": "CrossFit La Mola",
    "alternateName": "La Mola CrossFit",
    "description": "Box de CrossFit a Terrassa des de 2025. Entrenament funcional, halterofilia, gimnastic i cardio amb coaches certificats CF-L1 i CF-L2.",
    "url": "https://crossfitlamola.com/",
    "logo": "https://crossfitlamola.com/assets/logo-full.png",
    "image": "https://crossfitlamola.com/assets/hero-still.jpg",
    "telephone": "+34629066531",
    "email": "info@crossfitlamola.com",
    "priceRange": "EUR EUR",
    "foundingDate": "2025",
    "currenciesAccepted": "EUR",
    "paymentAccepted": "Credit Card, Bank Transfer, Direct Debit, Virtual POS",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Avinguda del Valles 724 C",
      "postalCode": "08227",
      "addressLocality": "Terrassa",
      "addressRegion": "Catalunya",
      "addressCountry": "ES"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "41.581285", "longitude": "2.027955" },
    "hasMap": "https://maps.app.goo.gl/LMWX4XfiVLq8PXxAA",
    "sameAs": [
      "https://www.instagram.com/lamolacrossfit/",
      "https://share.google/pTO0bMKcTnShi6oAO"
    ],
    "openingHoursSpecification": [
      {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"07:00","closes":"21:30"},
      {"@type":"OpeningHoursSpecification","dayOfWeek":["Saturday","Sunday"],"opens":"09:30","closes":"11:30"}
    ],
    "areaServed": [
      {"@type":"City","name":"Terrassa"},
      {"@type":"City","name":"Sabadell"},
      {"@type":"City","name":"Sant Cugat del Valles"},
      {"@type":"City","name":"Rubi"},
      {"@type":"AdministrativeArea","name":"Valles Occidental"}
