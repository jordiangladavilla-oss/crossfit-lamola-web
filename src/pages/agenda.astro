---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<Layout
  title="Agenda 2026 · CrossFit La Mola Terrassa"
  description="Calendari 2026 de competicions i events de CrossFit a Catalunya. Wodcelona, Basque Txapelketa, Summer Fest i més."
  canonical="https://crossfitlamola.com/agenda"
>
  <Fragment slot="head">
    <style>
      .cat-filters{ display:flex; flex-wrap:wrap; gap:8px; margin:44px 0 44px;}
      .cat-filter{ font-family:var(--f-mono); font-size:10.5px; letter-spacing:.2em; text-transform:uppercase; padding:10px 16px 9px; border:1px solid var(--line-ink-s); border-radius:999px; color:var(--bone-ink); opacity:.7; cursor:pointer; transition:all .2s; background:transparent;}
      .cat-filter:hover{ opacity:1;}
      .cat-filter.on{ background:var(--bone-ink); color:var(--bone); border-color:var(--bone-ink); opacity:1;}

      .month-band{ border-top:1px solid var(--line-ink); padding:44px 0 16px; position:relative;}
      .month-band:first-of-type{ border-top:none; padding-top:0;}
      .month-band .month-label{
        font-family:var(--f-display); font-weight:500; font-size:clamp(42px,5vw,72px);
        letter-spacing:-0.04em; line-height:.9; margin:0 0 4px;
        color:var(--bone-ink); display:flex; align-items:baseline; gap:14px;
      }
      .month-band .month-label em{ font-family:var(--f-serif); font-style:italic; font-weight:300; color:var(--accent-ink); font-size:.6em;}

      .event-list{ display:grid; gap:0; border-top:1px solid var(--line-ink-s); margin-top:28px;}
      .event{
        display:grid; grid-template-columns:1fr; gap:12px;
        padding:28px 0; border-bottom:1px solid var(--line-ink-s);
        align-items:baseline; transition:background .2s, padding .2s;
        position:relative;
      }
      @media(min-width:900px){
        .event{ grid-template-columns:110px 1fr 160px auto; gap:32px; align-items:center;}
      }
      .event.hidden{ display:none;}
      .event:hover{ background:var(--bone-soft); margin:0 -16px; padding-left:16px; padding-right:16px;}
      .event.featured{ background:var(--ink); color:var(--bone); padding:32px 24px; margin:12px 0; border-radius:2px; border-bottom:none;}
      .event.featured:hover{ padding:32px 24px;}

      .event .when{
        font-family:var(--f-display); font-weight:500; font-size:36px; letter-spacing:-0.035em;
        line-height:.9; color:var(--accent-ink);
      }
      .event.featured .when{ color:var(--accent-hi);}
      .event .when small{ display:block; font-family:var(--f-mono); font-size:10.5px; letter-spacing:.22em; text-transform:uppercase; margin-top:4px; color:var(--muted-ink);}
      .event.featured .when small{ color:var(--bone-3);}

      .event .meta{ display:grid; gap:4px;}
      .event .cat{ font-family:var(--f-mono); font-size:10.5px; letter-spacing:.22em; text-transform:uppercase; color:var(--muted-ink);}
      .event.featured .cat{ color:var(--bone-3);}
      .event h3{
        font-family:var(--f-display); font-weight:500; font-size:clamp(22px,2.4vw,30px);
        letter-spacing:-0.025em; line-height:1.05; margin:0;
      }
      .event h3 em{ font-family:var(--f-serif); font-style:italic; font-weight:300; color:var(--accent-ink);}
      .event.featured h3 em{ color:var(--accent-hi);}
      .event .desc{ font-family:var(--f-serif); font-size:15.5px; line-height:1.45; color:var(--bone-ink); opacity:.75; margin:6px 0 0; max-width:52ch;}
      .event.featured .desc{ color:var(--bone-2); opacity:1;}

      .event .place{ font-family:var(--f-mono); font-size:10.5px; letter-spacing:.18em; text-transform:uppercase; color:var(--bone-ink); opacity:.7;}
      .event.featured .place{ color:var(--bone-3);}

      .event .badge{
        font-family:var(--f-mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase;
        padding:6px 12px 5px; border-radius:999px; background:var(--accent-ink); color:var(--bone);
        white-space:nowrap;
      }
      .event.featured .badge{ background:var(--accent-hi); color:var(--ink);}
      .event .badge.secondary{ background:transparent; color:var(--accent-ink); border:1px solid var(--accent-ink);}

      .std-poster{
        margin-top:60px; padding:clamp(40px,6vw,80px) clamp(28px,4vw,60px);
        background:
          radial-gradient(circle at 20% 30%, rgba(185,169,114,.15) 0%, transparent 60%),
          radial-gradient(circle at 80% 70%, rgba(185,169,114,.10) 0%, transparent 55%),
          var(--ink);
        color:var(--bone); position:relative; overflow:hidden;
        display:grid; gap:20px; grid-template-columns:1fr;
      }
      @media(min-width:900px){ .std-poster{ grid-template-columns:1fr 1fr; align-items:end;} }
      .std-poster .label{ font-family:var(--f-mono); font-size:11px; letter-spacing:.24em; text-transform:uppercase; color:var(--accent-hi);}
      .std-poster h2{ font-family:var(--f-display); font-weight:500; font-size:clamp(52px,7vw,108px); letter-spacing:-0.04em; line-height:.9; margin:6px 0 0;}
      .std-poster h2 em{ font-family:var(--f-serif); font-style:italic; font-weight:300; color:var(--accent-hi);}
      .std-poster .when-big{ font-family:var(--f-display); font-weight:500; font-size:clamp(32px,4vw,52px); letter-spacing:-0.025em; line-height:1; margin-top:18px;}
      .std-poster .when-big small{ display:block; font-family:var(--f-mono); font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:var(--bone-3); margin-top:10px;}
      .std-poster .stars{ position:absolute; top:24px; right:24px; font-family:var(--f-mono); font-size:11px; letter-spacing:.22em; color:var(--accent-hi);}
      .std-poster .desc{ font-family:var(--f-serif); font-size:18px; line-height:1.4; color:var(--bone-2); margin:0; max-width:44ch;}

      .loading{ text-align:center; padding:60px 20px; font-family:var(--f-mono); font-size:12px; letter-spacing:.2em; text-transform:uppercase; color:var(--muted-ink);}

      .foot-col--thin a, .foot-col--thin p{ font-weight:300 !important; letter-spacing:.002em; }
      @media(min-width: 760px){ .foot-top{ grid-template-columns: 1.2fr 1fr 1fr 1fr 1fr !important; } }
    </style>
  </Fragment>

  <Nav currentPage="/agenda" />

  <section class="page-hero">
    <div class="bg" style="background-image:url('/assets/community-1.jpg')"></div>
    <div class="inner">
      <div class="crumb"><a href="/">Inici</a><span>/</span><span>Agenda</span></div>
      <div class="kicker"><span>Calendari</span><span class="bar"></span><span>Temporada 2026</span></div>
      <h1>Agenda<br><em class="serif">Temporada</em> 2026<span class="dot">.</span></h1>
      <p class="sub">Masterclasses, seminaris, competicions externes i events especials. Tot el que passa fora de l'horari setmanal.</p>
    </div>
  </section>

  <section class="sec bone">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">01 —</span><span>Events · 2026</span></div>
      <div style="height:16px"></div>
      <div class="sec-head">
        <h2 class="h-xl reveal">Tot el que<br>passa <em class="serif">aquest any</em><span class="dot">.</span></h2>
        <p class="lead reveal">Competicions externes, seminaris amb atletes convidats, masterclasses obertes i sortides de comunitat. Reserva per l'app o parla amb un coach.</p>
      </div>

      <div class="cat-filters reveal" id="cat-filters">
        <button class="cat-filter on" data-f="all">Tots</button>
        <button class="cat-filter" data-f="exterior">Exterior</button>
        <button class="cat-filter" data-f="interior">Interior</button>
        <button class="cat-filter" data-f="star">Destacat</button>
        <button class="cat-filter" data-f="free">Gratuït</button>
      </div>

      <div id="hero-event"></div>

      <div id="events-container">
        <div class="loading">Carregant events...</div>
      </div>
    </div>
  </section>

  <section class="cta-block">
    <div class="bg" style="background-image:url('/assets/hero-climb.jpg')"></div>
    <div class="inner">
      <div class="eyebrow reveal" style="color:var(--bone-3)"><span class="num" style="color:var(--accent-hi)">02 —</span><span>Inscripcions</span></div>
      <h2 class="h-hero reveal">Vols anar-hi<br><em class="serif">amb nosaltres</em><span class="dot">.</span></h2>
      <p class="reveal">Parla amb qualsevol coach o escriu-nos. T'expliquem com inscriure't, com preparar-te i amb qui aniras.</p>
      <div class="actions reveal">
        <a class="btn-primary" href="/contacte">Apuntar-me<span class="arr"></span></a>
        <a class="btn-ghost" href="https://wa.me/34629066531" target="_blank" rel="noopener">WhatsApp</a>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    const JSON_URL = 'https://raw.githubusercontent.com/jordiangladavilla-oss/lamola-tv-agenda2026/main/events.json';

    const MONTHS: Record<string, string> = {
      '01': 'Gener', '02': 'Febrer', '03': 'Març', '04': 'Abril',
      '05': 'Maig', '06': 'Juny', '07': 'Juliol', '08': 'Agost',
      '09': 'Setembre', '10': 'Octubre', '11': 'Novembre', '12': 'Desembre'
    };

    interface Event {
      id: string;
      startDate: string;
      endDate?: string;
      num: string;
      mes: string;
      month: string;
      title: string;
      titleShort: string;
      lede: string;
      pill: string;
      pillKind: string;
      sbSub: string;
      kicker?: string;
      isHero?: boolean;
    }

    async function loadEvents() {
      try {
        const res = await fetch(JSON_URL);
        const data = await res.json();
        const events: Event[] = data.events || [];

        const today = new Date().toISOString().split('T')[0];
        const futureEvents = events.filter(e => e.endDate ? e.endDate >= today : e.startDate >= today);

        futureEvents.sort((a, b) => a.startDate.localeCompare(b.startDate));

        const heroEvent = futureEvents.find(e => e.isHero);
        if (heroEvent) {
          renderHero(heroEvent);
        }

        const byMonth: Record<string, Event[]> = {};
        futureEvents.forEach(e => {
          const m = e.month;
          if (!byMonth[m]) byMonth[m] = [];
          byMonth[m].push(e);
        });

        renderEvents(byMonth);
        setupFilters();
      } catch (err) {
        console.error('Error carregant events:', err);
        document.getElementById('events-container')!.innerHTML =
          '<div class="loading">Error carregant events. Recarrega la pàgina.</div>';
      }
    }

    function renderHero(e: Event) {
      const container = document.getElementById('hero-event');
      if (!container) return;

      const date = new Date(e.startDate);
      const day = date.getDate().toString().padStart(2, '0');
      const monthName = MONTHS[e.month];
      const year = date.getFullYear();

      container.innerHTML = `
        <div class="std-poster reveal">
          <div>
            <span class="label">${e.kicker || 'Event destacat'}</span>
            <h2>${e.title}</h2>
            <p class="desc">${e.lede}</p>
          </div>
          <div>
            <div class="when-big">${day} ${monthName} ${year}<small>${e.sbSub}</small></div>
          </div>
          <div class="stars">* SAVE THE DATE *</div>
        </div>
      `;
    }

    function renderEvents(byMonth: Record<string, Event[]>) {
      const container = document.getElementById('events-container');
      if (!container) return;

      let html = '';
      const sortedMonths = Object.keys(byMonth).sort();

      sortedMonths.forEach(month => {
        const events = byMonth[month];
        const monthName = events[0]?.mes || MONTHS[month];

        html += `
          <div class="month-band reveal">
            <h3 class="month-label">${monthName} <em>· ${month}</em></h3>
            <div class="event-list">
        `;

        events.forEach(e => {
          const pillClass = e.pillKind === 'free' ? 'secondary' : '';
          html += `
            <div class="event" data-cat="${e.pillKind}">
              <div class="when">${e.num}<small>${e.mes}</small></div>
              <div class="meta">
                <span class="cat">${e.kicker || ''}</span>
                <h3>${e.title}</h3>
                <p class="desc">${e.lede}</p>
              </div>
              <div class="place">${e.sbSub.replace(' · ', '<br>')}</div>
              <span class="badge ${pillClass}">${e.pill}</span>
            </div>
          `;
        });

        html += `</div></div>`;
      });

      container.innerHTML = html;

      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      container.querySelectorAll('.reveal').forEach(el => io.observe(el));
    }

    function setupFilters() {
      const filtersEl = document.getElementById('cat-filters');
      if (!filtersEl) return;

      filtersEl.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const btn = target.closest('.cat-filter') as HTMLElement;
        if (!btn) return;

        filtersEl.querySelectorAll('.cat-filter').forEach(x => x.classList.remove('on'));
        btn.classList.add('on');

        const filter = btn.dataset.f || 'all';

        document.querySelectorAll('.event').forEach(ev => {
          const el = ev as HTMLElement;
          const cat = el.dataset.cat;
          el.classList.toggle('hidden', filter !== 'all' && cat !== filter);
        });

        document.querySelectorAll('.month-band').forEach(m => {
          const el = m as HTMLElement;
          const hasVisible = el.querySelectorAll('.event:not(.hidden)').length > 0;
          el.style.display = hasVisible ? '' : 'none';
        });
      });
    }

    loadEvents();
  </script>
</Layout>
