  <Footer />

  <script>
    const liveStatus = document.getElementById('live-status');
    if (liveStatus) {
      const d = new Date();
      const day = d.getDay();
      const hm = d.getHours() + d.getMinutes() / 60;
      let open = false;
      if (day >= 1 && day <= 5) open = hm >= 6.5 && hm < 21.5;
      else if (day === 6 || day === 0) open = hm >= 9 && hm < 12;
      liveStatus.textContent = open ? 'Class in progress · View schedule' : 'Closed · Come back tomorrow';
    }

    const filterStrip = document.getElementById('filter-strip');
    const agendaList = document.getElementById('agenda-list');
    if (filterStrip && agendaList) {
      filterStrip.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.chip');
        if (!btn) return;
        filterStrip.querySelectorAll('.chip').forEach(c => c.classList.remove('is-active'));
        btn.classList.add('is-active');
        const filter = btn.getAttribute('data-filter');
        agendaList.querySelectorAll('.agenda-row').forEach(row => {
          const el = row as HTMLElement;
          el.style.display = (filter === 'all' || el.dataset.cat === filter) ? '' : 'none';
        });
      });
    }

    // Form submission
    const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwHm_4Rwt_x9RN5q1PEKxTzXj587hgKYp70WqyNA9DpbETdy-dcUPt2n3YtaZ7KFJinww/exec';

    function getSource() {
      const params = new URLSearchParams(window.location.search);
      const utm = params.get('utm_source');
      if (utm) return utm;
      const from = params.get('from');
      if (from) return from;
      return 'web';
    }

    const homeForm = document.getElementById('home-form') as HTMLFormElement;

    if (homeForm) {
      homeForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target as HTMLFormElement;
        const btn = document.getElementById('home-submit') as HTMLButtonElement;
        const msg = document.getElementById('home-msg') as HTMLElement;
        const btnText = btn.innerHTML;

        btn.innerHTML = 'Sending...';
        btn.disabled = true;
        msg.style.display = 'none';

        const source = getSource();
        const data = {
          origen: 'Home EN (' + source + ')',
          name: (form.querySelector('[name="name"]') as HTMLInputElement).value,
          email: (form.querySelector('[name="email"]') as HTMLInputElement).value,
          phone: (form.querySelector('[name="phone"]') as HTMLInputElement).value,
          topic: (form.querySelector('[name="topic"]') as HTMLSelectElement).value,
          schedule: (form.querySelector('[name="schedule"]') as HTMLSelectElement).value,
          message: (form.querySelector('[name="message"]') as HTMLTextAreaElement).value,
          website: (form.querySelector('[name="website"]') as HTMLInputElement).value
        };

        try {
          await fetch(SCRIPT_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });

          msg.style.display = 'block';
          msg.style.background = 'var(--accent-ink)';
          msg.style.color = 'var(--bone)';
          msg.innerHTML = '<strong>Thank you!</strong> We received your message. We\'ll be in touch soon.';
          form.reset();

          // Google Analytics conversion event
          if (typeof gtag !== 'undefined') {
            gtag('event', 'generate_lead', {
              event_category: 'forms',
              event_label: 'Home EN',
              value: 1
            });
          }
        } catch (err) {
          msg.style.display = 'block';
          msg.style.background = '#fee';
          msg.style.color = '#c00';
          msg.innerHTML = 'Error sending. Try WhatsApp: <a href="https://wa.me/34629066531" style="color:#c00;">629 06 65 31</a>';
        }

        btn.innerHTML = btnText;
        btn.disabled = false;
      });
    }
  </script>
