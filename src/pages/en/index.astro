---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import Schema from '../../components/Schema.astro'
import { agendaEvents, formatEventDays, getEventMonthShort, getEventName, getEventPlace } from '../../data/agenda'

// Transform events for the index agenda section format
const AGENDA = agendaEvents.slice(0, 6).map(e => {
  const placeParts = getEventPlace(e, 'en').split(' · ')
  return {
    d: formatEventDays(e),
    m: getEventMonthShort(e, 'en'),
    title: getEventName(e, 'en'),
    cat: e.cat === 'comp-ext' ? 'competicio' : e.cat,
    meta: placeParts,
    tag: e.featured || false,
    note: ''
  }
})
---

<Layout
  title="CrossFit La Mola | CrossFit Box Terrassa - Functional Training"
  description="CrossFit box in Terrassa, Barcelona. Functional training for all levels with certified coaches. Free first class."
  canonical="https://crossfitlamola.com/en"
  bodyData={{ "data-hero": "full" }}
>
  <Schema type="home" slot="head" />
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Can I do CrossFit if I'm not in shape?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. That's where everyone starts. Every movement has a simpler version and a coach will be with you from day one until your body feels comfortable."
          }
        },
        {
          "@type": "Question",
          "name": "Will I bulk up quickly?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Getting 'too muscular' is a much longer and more specific project than coming three days a week. What you'll find is shape, posture, and a body that handles daily life better."
          }
        },
        {
          "@type": "Question",
          "name": "Will I get injured doing CrossFit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If things are done right, no. The program is designed to progress safely, not to force unnecessary limits. Weights adapt to each person, technique is always the priority and coaches correct in the moment so each movement is done with control and purpose."
          }
        },
        {
          "@type": "Question",
          "name": "What if I don't know anyone at the box?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "That's the most common case. Within two weeks there'll be names and faces that already know yours. In a community, this happens effortlessly."
          }
        },
        {
          "@type": "Question",
          "name": "Am I too old for CrossFit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The community includes people from 19 to over 60. Age isn't a barrier, it's a variable. We always scale the programming to your level."
          }
        },
        {
          "@type": "Question",
          "name": "What does the free first class include?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "One hour with a coach who does a brief initial assessment, explains the movement of the day and accompanies you so you train with the rest of the group at your pace. You don't need to know anything beforehand or come prepared in any specific way, just participate and understand how we work. And after that, there's no commitment, just the experience of having tried it."
          }
        },
        {
          "@type": "Question",
          "name": "How much does CrossFit La Mola cost and what does each plan include?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There are monthly memberships based on days per week, and 10-class packs. No long-term commitment. We'll walk you through everything calmly after your first class, or message us on WhatsApp and we'll talk."
          }
        }
      ]
    }
    </script>
  </Fragment>

  <Nav currentPage="/" />

  <main id="main">
  <section class="hero" id="top">
    <div class="hero-grid">
      <div class="hero-media">
        <video autoplay muted loop playsinline preload="metadata" poster="/assets/hero-still.jpg">
          <source src="/assets/hero.mp4" type="video/mp4">
        </video>
      </div>

      <div class="hero-copy">
        <div>
          <div class="hero-kicker">
            <span>Move with purpose</span>
            <span class="bar"></span>
            <span>Terrassa · CrossFit Affiliate</span>
          </div>
          <h1 class="visually-hidden">CrossFit La Mola · CrossFit box in Terrassa.</h1>
          <img class="hero-logo" src="/assets/logo-full.png" alt="CrossFit La Mola. Build strength together.">
        </div>

        <div class="hero-bottom-row">
          <p class="hero-sub">
            3 coaches. 9 disciplines. One space.<br>
            You bring the effort, consistency does the rest.
          </p>
          <a class="hero-cta" href="/en/contacte">
            Book your trial class
            <span class="arr"></span>
          </a>
        </div>

        <div class="hero-meta">
          <span><span class="k">CrossFit</span> <span class="v">Affiliate</span></span>
          <span><span class="k">Athletes</span> <span class="v">+250</span></span>
          <span><span class="k">Coaches</span> <span class="v">03</span></span>
          <span><span class="k">Classes/week</span> <span class="v">60+</span></span>
        </div>
      </div>
    </div>
  </section>

  <div class="status-strip">
    <span class="live" id="live-status">Class in progress · View schedule</span>
    <span>Mon–Thu 07:00–21:30 · Fri 07:00–20:30 · Sat–Sun 09:30–11:30</span>
    <span>Av. del Vallès 724C · 08227 Terrassa</span>
  </div>

  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span>
        WOD <em>·</em> Weightlifting <span class="sep"></span>
        Hybrid Club <em>·</em> Bodyweight Lab <span class="sep"></span>
        Strength Club <em>·</em> Abs &amp; Cals <span class="sep"></span>
        The Program <em>·</em> Train with your Coach <span class="sep"></span>
        Running Club <em>·</em>
      </span>
      <span>
        WOD <em>·</em> Weightlifting <span class="sep"></span>
        Hybrid Club <em>·</em> Bodyweight Lab <span class="sep"></span>
        Strength Club <em>·</em> Abs &amp; Cals <span class="sep"></span>
        The Program <em>·</em> Train with your Coach <span class="sep"></span>
        Running Club <em>·</em>
      </span>
    </div>
  </div>

  <section class="sec bone" id="manifest">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">01</span><span>Move with purpose</span></div>
      <div style="height: 32px"></div>
      <div class="manifest">
        <h2 class="h-xl reveal">
          Same routine.<br>Every <em class="serif">single day</em><span class="dot">.</span>
        </h2>
        <div class="manifest-body reveal">
          <p>The door opens and, with the first contact of the bars with the floor, a process begins that repeats and evolves with each session: it's not just moving weight, but building a solid foundation with consistency. Over time, strength consolidates and confidence grows as you understand your body and what it's capable of.</p>
          <p class="sig">Sergi · Juse · Eli</p>
        </div>
      </div>
    </div>
  </section>

  <section class="sec bone" id="story" style="padding-top: 0;">
    <div class="inner">
      <div style="border-top: 1px solid var(--line-ink); padding-top: clamp(60px, 8vw, 100px)"></div>
      <div class="story-grid">
        <div class="story-copy reveal">
          <div class="eyebrow"><span class="num">02</span><span>Respect the craft</span></div>
          <h2 class="h-xl">The name comes from a<br><em class="serif">mountain</em><span class="dot">.</span></h2>
          <p>La Mola crowns Terrassa and represents a way of understanding effort: advancing step by step, accepting the incline and maintaining a constant rhythm. This same logic defines how we train at the box: it's not about reaching the highest point in a single day, but about coming back week after week and realizing that, almost without making noise, you're already a bit higher than before.</p>
          <a href="/en/el-box" class="story-link">Explore the box <span class="arr"></span></a>
        </div>
        <div class="story-images reveal-stagger">
          <figure class="tall" style="--i:0"><img src="/assets/lamola-climb.jpg" alt="Athlete doing rope climb at CrossFit La Mola, like climbing La Mola step by step" loading="lazy"></figure>
          <figure style="--i:1"><img src="/assets/detail-chalk.webp" alt="Athlete's chalked hand preparing for a lift" loading="lazy"></figure>
          <figure style="--i:2"><img src="/assets/detail-dumbbells.webp" alt="Competition dumbbell rack in the box" loading="lazy"></figure>
          <figure style="--i:3"><img src="/assets/class-weightlifting.webp" alt="Athlete doing weightlifting with barbell overhead at the box" loading="lazy"></figure>
          <figure style="--i:4"><img src="/assets/detail-rope.webp" alt="Battle rope coiled on the box floor" loading="lazy"></figure>
        </div>
      </div>
    </div>
  </section>

  <section class="sec bone" id="disciplines" style="padding-top: clamp(60px, 8vw, 120px)">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">03</span><span>Leave no one behind</span></div>
      <div style="height: 24px"></div>
      <div class="disc-head">
        <h2 class="h-xl reveal">9 disciplines.<br><em class="serif">One philosophy</em><span class="dot">.</span></h2>
        <p class="reveal">The center is the WOD, where weightlifting, gymnastics and hybrid work combine to develop complete performance. From there, each discipline is also worked specifically to consolidate technique and progression, with powerlifting and Abs & Cals sessions as the foundation that sustains the whole.</p>
      </div>
      <div class="disc-grid reveal-stagger">
        <a href="/en/classes" class="disc-card" style="--i:0">
          <div class="img"><img src="/assets/class-wod.webp" alt="WOD class at CrossFit La Mola with group of athletes and coach explaining the workout" loading="lazy"></div>
          <div class="body">
            <div class="tag">Every day · Core</div>
            <h3>WOD</h3>
            <p>The essence of CrossFit. Warm-up, strength or skill, and a METCON that changes daily. Five days a week, plus a WOD in pairs on Saturdays.</p>
            <span class="link">View class →</span>
          </div>
        </a>
        <a href="/en/classes" class="disc-card" style="--i:1">
          <div class="img"><img src="/assets/class-weightlifting.webp" alt="Athlete performing jerk with Olympic barbell during Weightlifting class" loading="lazy"></div>
          <div class="body">
            <div class="tag">Olympic lifting · Technique</div>
            <h3>Weightlifting</h3>
            <p>Snatch, clean and jerk. The three star movements demand detail and patience. We lift better first. Lifting heavy comes after.</p>
            <span class="link">View class →</span>
          </div>
        </a>
        <a href="/en/classes" class="disc-card" style="--i:2">
          <div class="img"><img src="/assets/class-hybrid.webp" alt="Athletes training on Concept2 BikeERG during Hybrid Club class" loading="lazy"></div>
          <div class="body">
            <div class="tag">Strength + Endurance</div>
            <h3>Hybrid Club</h3>
            <p>Training hard without the technical barrier. Strength and endurance combined with simple movements, no Olympic lifting or complex gymnastics.</p>
            <span class="link">View class →</span>
          </div>
        </a>
        <a href="/en/classes" class="disc-card" style="--i:3">
          <div class="img"><img src="/assets/class-bodyweight.webp" alt="Athletes performing rope climb during Bodyweight Lab class" loading="lazy"></div>
          <div class="body">
            <div class="tag">Gymnastics · Base / Advance</div>
            <h3>Bodyweight Lab</h3>
            <p>We control the body by breaking down gymnastic movements. Base for beginners; Advance for butterfly, BMU, HSW and HSPU.</p>
            <span class="link">View class →</span>
          </div>
        </a>
        <a href="/en/classes" class="disc-card" style="--i:4">
          <div class="img"><img src="/assets/class-strength.webp" alt="Group of athletes with Olympic barbells during Strength Club class" loading="lazy"></div>
          <div class="body">
            <div class="tag">Pure strength · 2 days/week</div>
            <h3>Strength Club</h3>
            <p>Two days a week dedicated to strength. Squat, deadlift and press, with variations to reinforce stability and core.</p>
            <span class="link">View class →</span>
          </div>
        </a>
        <a href="/en/classes" class="disc-card" style="--i:5">
          <div class="img"><img src="/assets/class-abs.webp" alt="Athlete training on Concept2 rower during Abs and Cals class" style="object-position: center top;" loading="lazy"></div>
          <div class="body">
            <div class="tag">Machines · Core</div>
            <h3>Abs &amp; Cals</h3>
            <p>Row, ski erg, bike erg and echo bike, combined with specific core work. Designed to improve your WOD performance.</p>
            <span class="link">View class →</span>
          </div>
        </a>
        <a href="/en/classes" class="disc-card" style="--i:6">
          <div class="img"><img src="/assets/class-program.webp" alt="Coach explaining the WOD on the whiteboard with athletes listening" loading="lazy"></div>
          <div class="body">
            <div class="tag">Competition · RX · Cycles</div>
            <h3>The Program</h3>
            <p>For those who want to compete. Three weekly sessions following RX programming, structured in cycles for solid, consistent progress.</p>
            <span class="link">View class →</span>
          </div>
        </a>
        <a href="/en/classes" class="disc-card" style="--i:7">
          <div class="img"><img src="/assets/class-coach.webp" alt="Coach wearing La Mola shirt supervising athlete training" loading="lazy"></div>
          <div class="body">
            <div class="tag">90 min · Shared programming</div>
            <h3>Train with your Coach</h3>
            <p>Three days a week we train 90 minutes alongside one of the coaches. It's not a directed class: you follow the same whiteboard and adapt movements to your level.</p>
            <span class="link">View class →</span>
          </div>
        </a>
        <a href="/en/classes" class="disc-card" style="--i:8">
          <div class="img"><img src="/assets/class-running.webp" alt="Two athletes smiling while training on Echo Bikes" loading="lazy"></div>
          <div class="body">
            <div class="tag">Running · In community</div>
            <h3>Running Club</h3>
            <p>Add running to your training and do it in community. A space to share the run with other athletes.</p>
            <span class="link">View class →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="sec ink" id="coaches">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">04</span><span>100 fades · Strength stays</span></div>
      <div style="height: 24px"></div>
      <div class="coaches-head">
        <h2 class="h-xl reveal">3 people.<br>One way of<br>understanding <em class="serif">movement</em><span class="dot">.</span></h2>
        <p class="reveal">Three people, one same way of understanding movement. They program with criteria and correct with precision to accompany you properly at each stage of the process.</p>
      </div>
      <div class="coaches-grid reveal-stagger">
        <article class="coach" style="--i:0">
          <div class="photo">
            <span class="tag">01 · Head Coach</span>
            <img src="/assets/coach-sergi.jpg" alt="Sergi, head coach and co-founder of CrossFit La Mola, CF-L2 certified" loading="lazy">
          </div>
          <h3>Sergi</h3>
          <div class="coach-kvs">
            <span class="k">In love with</span> <span class="v">Squat snatch</span>
            <span class="k">Kryptonite</span> <span class="v">Wall climbs</span>
            <span class="k">Work in progress</span> <span class="v">Free handstand push-up</span>
          </div>
          <p class="coach-quote">"Coaching is teaching, but mostly learning. CrossFit is the foundation of my day—mental and physical strength in one hour."</p>
        </article>
        <article class="coach" style="--i:1">
          <div class="photo">
            <span class="tag">02 · Coach</span>
            <img src="/assets/coach-juse.jpg" alt="Juse, coach at CrossFit La Mola, CF-L1 certified" loading="lazy">
          </div>
          <h3>Juse</h3>
          <div class="coach-kvs">
            <span class="k">In love with</span> <span class="v">Squat clean</span>
            <span class="k">Kryptonite</span> <span class="v">Strict HSPU</span>
            <span class="k">Work in progress</span> <span class="v">HSW ramp</span>
          </div>
          <p class="coach-quote">"The snatch and clean are not tricks, but the result of hours of practice and attention to detail. Come with patience: what you're looking for you already carry inside, and it's built through consistency, refining it day after day."</p>
        </article>
        <article class="coach" style="--i:2">
          <div class="photo">
            <span class="tag">03 · Coach</span>
            <img src="/assets/coach-eli.jpg" alt="Eli, coach and co-founder of CrossFit La Mola, CF-L1 certified" loading="lazy">
          </div>
          <h3>Eli</h3>
          <div class="coach-kvs">
            <span class="k">In love with</span> <span class="v">Wall climbs</span>
            <span class="k">Kryptonite</span> <span class="v">HSPU</span>
            <span class="k">Work in progress</span> <span class="v">Snatch</span>
          </div>
          <p class="coach-quote">"For me, CrossFit is peace of mind. Reconnecting, appreciating my body. Technique before weight. Progress is never linear."</p>
        </article>
      </div>
    </div>
  </section>

  <section class="sec bone" id="agenda">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">05</span><span>Support · Encourage</span></div>
      <div style="height: 24px"></div>
      <div class="schedule-head">
        <h2 class="h-xl reveal">More than<br><em class="serif">training</em><span class="dot">.</span></h2>
        <p class="reveal">Things happen outside the box. Mountain outings. Beach WODs, competitions, parties. The community is what sustains this box and makes it grow beyond each session. These are the upcoming dates.</p>
      </div>
      <div class="schedule-strip" id="filter-strip">
        <button class="chip is-active" data-filter="all">All</button>
        <button class="chip" data-filter="activitat">Activities</button>
        <button class="chip" data-filter="competicio">Competitions</button>
      </div>
      <div class="agenda" id="agenda-list" aria-live="polite">
        {AGENDA.map(item => (
          <div class={`agenda-row ${item.tag ? 'tag' : ''}`} data-cat={item.cat}>
            <div class="date">{item.d}<span class="m">{item.m}</span></div>
            <div class="title">{item.title}</div>
            <div class="meta">{item.meta.map((m, i) => <><span>{m}</span>{i < item.meta.length - 1 && <span class="sep">·</span>}</>)}</div>
            <div class="note">{item.note}</div>
          </div>
        ))}
      </div>
      <div class="agenda-foot">
        <span>Own source</span>
        <a href="/en/agenda">View full calendar →</a>
      </div>
    </div>
  </section>

  <section class="sec ink" id="comunitat">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">06</span><span>You show up · We stay</span></div>
      <div style="height: 24px"></div>
      <div class="comm-head">
        <h2 class="h-xl reveal">The people <em class="serif">who make</em> the box<span class="dot">.</span></h2>
        <p class="reveal">Some people seek health, others performance or competition. There are also those who come to disconnect, socialize or find a space where they feel comfortable and safe. Here everyone scales, everyone progresses and everyone has their space.</p>
      </div>
      <div class="comm-grid reveal-stagger">
        <figure class="wide" style="--i:0"><img src="/assets/RAQ_7644.jpg" alt="The full CrossFit La Mola team: coaches and athletes together at the box" loading="lazy"></figure>
        <figure style="--i:2"><img src="/assets/detail-chalk.webp" alt="Athlete's chalked hand preparing for a lift" loading="lazy"></figure>
        <div class="quote-card" style="--i:3">
          <blockquote>"Great atmosphere, excellent professionals, family-friendly with very good facilities."</blockquote>
          <cite>Marc · December 2025 · <a href="https://goo.gl/maps/v5yuvhn1jXABGmbY8?g_st=aw" target="_blank" rel="noopener">See review</a></cite>
        </div>
        <figure class="tall" style="--i:4"><img src="/assets/community-7.webp" alt="Group of athletes cheering on a teammate during the WOD" loading="lazy"></figure>
        <figure style="--i:5"><img src="/assets/community-4.webp" alt="Two athletes smiling while training on Echo Bikes" loading="lazy"></figure>
        <figure style="--i:6"><img src="/assets/community-6.webp" alt="Athletes training together in CrossFit class" loading="lazy"></figure>
        <div class="quote-card" style="--i:7">
          <blockquote>"Without a doubt the best box I've ever been to. They're very approachable, attentive, always looking out for you. Everything is organized, clean and impeccable. Plus, they never stop innovating and improving. A pleasure to train here!"</blockquote>
          <cite>Eva · April 2025 · <a href="https://goo.gl/maps/HP3B6uTDn8vEuixR6?g_st=aw" target="_blank" rel="noopener">See review</a></cite>
        </div>
        <figure style="--i:8"><img src="/assets/community-4.2.webp" alt="Three athletes celebrating after an intense workout" loading="lazy"></figure>
        <figure class="wide" style="--i:9"><img src="/assets/community-group.jpg" alt="Large group of athletes posing together at the box" loading="lazy"></figure>
        <figure class="tall" style="--i:10"><img src="/assets/community-8.webp" alt="Athlete performing ring muscle-ups during WOD" loading="lazy"></figure>
      </div>
    </div>
  </section>

  <section class="sec bone" id="faq">
    <div class="inner">
      <div class="faq-head">
        <div class="eyebrow reveal"><span class="num">07</span><span>Frequently asked questions</span></div>
        <h2 class="h-xl reveal">Everything you need to <em class="serif">know</em><span class="dot">.</span></h2>
      </div>
      <div class="faq reveal">
        <details>
          <summary>Can I do CrossFit if I'm not in shape?<span class="sign"></span></summary>
          <p class="a">Yes. That's where everyone starts. Every movement has a simpler version and a coach will be with you from day one until your body feels comfortable.</p>
        </details>
        <details>
          <summary>Will I bulk up quickly?<span class="sign"></span></summary>
          <p class="a">No. Getting "too muscular" is a much longer and more specific project than coming three days a week. What you'll find is shape, posture, and a body that handles daily life better.</p>
        </details>
        <details>
          <summary>Will I get injured?<span class="sign"></span></summary>
          <p class="a">If things are done right, no. The program is designed to progress safely, not to force unnecessary limits. Weights adapt to each person, technique is always the priority and coaches correct in the moment so each movement is done with control and purpose.</p>
        </details>
        <details>
          <summary>What if I don't know anyone?<span class="sign"></span></summary>
          <p class="a">That's the most common case. Within two weeks there'll be names and faces that already know yours. In a community, this happens effortlessly.</p>
        </details>
        <details>
          <summary>Am I too old?<span class="sign"></span></summary>
          <p class="a">The community includes people from 19 to over 60. Age isn't a barrier, it's a variable. We always scale the programming to your level.</p>
        </details>
        <details>
          <summary>What if I make a fool of myself?<span class="sign"></span></summary>
          <p class="a">Here no one is watching to judge how you do it. We've all been there at some point. At the box there are no spectators, just people training, each in their own process.</p>
        </details>
        <details>
          <summary>What does the free first class include?<span class="sign"></span></summary>
          <p class="a">One hour with a coach who does a brief initial assessment, explains the movement of the day and accompanies you so you train with the rest of the group at your pace. You don't need to know anything beforehand or come prepared in any specific way, just participate and understand how we work. And after that, there's no commitment, just the experience of having tried it.</p>
        </details>
        <details>
          <summary>How much does it cost and what does each plan include?<span class="sign"></span></summary>
          <p class="a">There are monthly memberships based on days per week, and 10-class packs. No long-term commitment. We'll walk you through everything calmly after your first class, or message us on WhatsApp and we'll talk.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="sec ink" id="contact">
    <div class="inner">
      <div class="contact-head">
        <div class="eyebrow reveal"><span class="num">08</span><span>Progress over perfection</span></div>
        <h2 class="h-xl reveal">First class free.<br><em class="serif">On us</em><span class="dot">.</span></h2>
        <p class="reveal">You tell us a bit about yourself, we help you find the schedule that best fits you and we'll see you at the box to start. No pressure or expectations, you get to know how we work and decide calmly if you want to come back.</p>
      </div>
      <div class="contact-grid">
        <form class="contact-form reveal" id="home-form">
