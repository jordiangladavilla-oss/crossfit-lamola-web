---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import {
  agendaEvents,
  getEventsByMonth,
  getFeaturedEvent,
  formatEventDays,
  getEventDayName,
  getEventName,
  getEventPlace,
  getEventDesc,
  catLabels,
  monthNames,
  type AgendaEvent
} from '../../data/agenda'

const lang = 'en'
const eventsByMonth = getEventsByMonth(lang)
const featuredEvent = getFeaturedEvent()

const AGENDA_EVENTS_2026 = agendaEvents.map(e => ({
  name: e.nameEn || e.name,
  start: e.start,
  end: e.end,
  place: e.placeEn || e.place,
  desc: e.descEn || e.desc || '',
  cat: e.cat
}))

function isDateRange(event: AgendaEvent): boolean {
  return event.start !== event.end
}

function getBadgeText(event: AgendaEvent): string {
  if (event.cat === 'comp-ext') return 'External competition'
  if (event.cat === 'seminari') return event.place.includes('€') ? event.place.split('·').pop()?.trim() || 'Seminar' : 'Seminar'
  if (event.cat === 'festa') return 'Save the date'
  if (event.cat === 'masterclass') return 'Free'
  const place = event.placeEn || event.place
  return place.split('·').pop()?.trim() || ''
}
---

<Layout
  title="Calendar 2026 · CrossFit La Mola Terrassa"
  description="2026 calendar of CrossFit competitions and events in Catalonia. Wodcelona, Basque Txapelketa, Summer Fest and more."
>
  <Fragment slot="head">
    <style>
      .cat-filters{ display:flex; flex-wrap:wrap; gap:8px; margin:44px 0 44px;}
      .cat-filter{ font-family:var(--f-mono); font-size:10.5px; letter-spacing:.2em; text-transform:uppercase; padding:10px 16px 9px; border:1px solid var(--line-ink-s); border-radius:999px; color:var(--bone-ink); opacity:.7; cursor:pointer; transition:all .2s; background:transparent;}
      .cat-filter:hover{ opacity:1;}
      .cat-filter.on{ background:var(--bone-ink); color:var(--bone); border-color:var(--bone-ink); opacity:1;}

      .month-band{ border-top:1px solid var(--line-ink); padding:44px 0 16px; position:relative;}
      .month-band:first-of-type{ border-top:none; padding-top:0;}
      .month-band .month-label{ font-family:var(--f-display); font-weight:500; font-size:clamp(42px,5vw,72px); letter-spacing:-0.04em; line-height:.9; margin:0 0 4px; color:var(--bone-ink); display:flex; align-items:baseline; gap:14px;}
      .month-band .month-label em{ font-family:var(--f-serif); font-style:italic; font-weight:300; color:var(--accent-ink); font-size:.6em;}

      .event-list{ display:grid; gap:0; border-top:1px solid var(--line-ink-s); margin-top:28px;}
      .event{ display:grid; grid-template-columns:1fr; gap:12px; padding:28px 0; border-bottom:1px solid var(--line-ink-s); align-items:baseline; transition:background .2s, padding .2s; position:relative;}
      @media(min-width:900px){ .event{ grid-template-columns:110px 1fr 160px auto; gap:32px; align-items:center;} }
      .event.hidden{ display:none;}
      .event:hover{ background:var(--bone-soft); margin:0 -16px; padding-left:16px; padding-right:16px;}
      .event.featured{ background:var(--ink); color:var(--bone); padding:32px 24px; margin:12px 0; border-radius:2px; border-bottom:none;}
      .event.featured:hover{ padding:32px 24px;}

      .event .when{ font-family:var(--f-display); font-weight:500; font-size:36px; letter-spacing:-0.035em; line-height:.9; color:var(--accent-ink);}
      .event.featured .when{ color:var(--accent-hi);}
      .event .when small{ display:block; font-family:var(--f-mono); font-size:10.5px; letter-spacing:.22em; text-transform:uppercase; margin-top:4px; color:var(--muted-ink);}
      .event.featured .when small{ color:var(--bone-3);}

      .event .meta{ display:grid; gap:4px;}
      .event .cat{ font-family:var(--f-mono); font-size:10.5px; letter-spacing:.22em; text-transform:uppercase; color:var(--muted-ink);}
      .event.featured .cat{ color:var(--bone-3);}
      .event h3{ font-family:var(--f-display); font-weight:500; font-size:clamp(22px,2.4vw,30px); letter-spacing:-0.025em; line-height:1.05; margin:0;}
      .event h3 em{ font-family:var(--f-serif); font-style:italic; font-weight:300; color:var(--accent-ink);}
      .event.featured h3 em{ color:var(--accent-hi);}
      .event .desc{ font-family:var(--f-serif); font-size:15.5px; line-height:1.45; color:var(--bone-ink); opacity:.75; margin:6px 0 0; max-width:52ch;}
      .event.featured .desc{ color:var(--bone-2); opacity:1;}

      .event .place{ font-family:var(--f-mono); font-size:10.5px; letter-spacing:.18em; text-transform:uppercase; color:var(--bone-ink); opacity:.7;}
      .event.featured .place{ color:var(--bone-3);}

      .event .badge{ font-family:var(--f-mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; padding:6px 12px 5px; border-radius:999px; background:var(--accent-ink); color:var(--bone); white-space:nowrap;}
      .event.featured .badge{ background:var(--accent-hi); color:var(--ink);}
      .event .badge.secondary{ background:transparent; color:var(--accent-ink); border:1px solid var(--accent-ink);}

      .std-poster{ margin-top:60px; padding:clamp(40px,6vw,80px) clamp(28px,4vw,60px); background:radial-gradient(circle at 20% 30%, rgba(185,169,114,.15) 0%, transparent 60%),radial-gradient(circle at 80% 70%, rgba(185,169,114,.10) 0%, transparent 55%),var(--ink); color:var(--bone); position:relative; overflow:hidden; display:grid; gap:20px; grid-template-columns:1fr;}
      @media(min-width:900px){ .std-poster{ grid-template-columns:1fr 1fr; align-items:end;} }
      .std-poster .label{ font-family:var(--f-mono); font-size:11px; letter-spacing:.24em; text-transform:uppercase; color:var(--accent-hi);}
      .std-poster h2{ font-family:var(--f-display); font-weight:500; font-size:clamp(52px,7vw,108px); letter-spacing:-0.04em; line-height:.9; margin:6px 0 0;}
      .std-poster h2 em{ font-family:var(--f-serif); font-style:italic; font-weight:300; color:var(--accent-hi);}
      .std-poster .when-big{ font-family:var(--f-display); font-weight:500; font-size:clamp(32px,4vw,52px); letter-spacing:-0.025em; line-height:1; margin-top:18px;}
      .std-poster .when-big small{ display:block; font-family:var(--f-mono); font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:var(--bone-3); margin-top:10px;}
      .std-poster .stars{ position:absolute; top:24px; right:24px; font-family:var(--f-mono); font-size:11px; letter-spacing:.22em; color:var(--accent-hi);}
      .std-poster .desc{ font-family:var(--f-serif); font-size:18px; line-height:1.4; color:var(--bone-2); margin:0; max-width:44ch;}
    </style>
    <script type="application/ld+json" set:html={JSON.stringify(AGENDA_EVENTS_2026.map(e => ({
      "@context":"https://schema.org",
      "@type":"SportsEvent",
      "name": e.name,
      "description": e.desc,
      "startDate": e.start,
      "endDate": e.end,
      "eventStatus":"https://schema.org/EventScheduled",
      "eventAttendanceMode":"https://schema.org/OfflineEventAttendanceMode",
      "sport": "CrossFit",
      "location":{
        "@type":"Place",
        "name": e.place.split('·')[0].trim(),
        "address":{"@type":"PostalAddress","addressLocality":"Terrassa","addressRegion":"Catalunya","addressCountry":"ES"}
      },
      "organizer":{"@id":"https://crossfitlamola.com/#organization"},
      "performer":{"@id":"https://crossfitlamola.com/#organization"}
    })))} />
  </Fragment>

  <Nav currentPage="/en/agenda" />

  <section class="page-hero">
    <div class="bg" style="background-image:url('/assets/community-1.jpg')"></div>
    <div class="inner">
      <div class="crumb"><a href="/en">Home</a><span>/</span><span>Calendar</span></div>
      <div class="kicker"><span>Calendar</span><span class="bar"></span><span>2026 Season</span></div>
      <h1>Calendar<br><em class="serif">Season</em> 2026<span class="dot">.</span></h1>
      <p class="sub">Masterclasses, seminars, external competitions and special events.</p>
    </div>
  </section>

  <section class="sec bone">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">01 —</span><span>Events · 2026</span></div>
      <div style="height:16px"></div>
      <div class="sec-head">
        <h2 class="h-xl reveal">Everything happening<br><em class="serif">this year</em><span class="dot">.</span></h2>
        <p class="lead reveal">External competitions, seminars with guest athletes, open masterclasses and community outings.</p>
      </div>

      <div class="cat-filters reveal" id="cat-filters">
        <button class="cat-filter on" data-f="all">All</button>
        <button class="cat-filter" data-f="comp-ext">Competitions</button>
        <button class="cat-filter" data-f="activitat">Activities</button>
      </div>

      {featuredEvent && (
        <div class="std-poster reveal">
          <div>
            <span class="label">{catLabels[lang][featuredEvent.cat]} · La Mola</span>
            <h2>La Mola.<br>Summer <em>Fest</em><span class="dot">.</span></h2>
            <p class="desc">{getEventDesc(featuredEvent, lang)}</p>
          </div>
          <div>
            <div class="when-big">
              {formatEventDays(featuredEvent)} {monthNames[lang][new Date(featuredEvent.start).getMonth()]} 2026
              <small>{featuredEvent.place.split('·')[1]?.trim() || ''} · CrossFit La Mola</small>
            </div>
          </div>
          <div class="stars">* SAVE THE DATE *</div>
        </div>
      )}

      {[...eventsByMonth.entries()].map(([monthLabel, events], idx) => (
        <div class="month-band reveal" style={idx === 0 ? "margin-top:80px;" : ""}>
          <h3 class="month-label">
            {monthLabel.split(' ')[0]}
            <em>· {(new Date(events[0].start).getMonth() + 1).toString().padStart(2, '0')}</em>
          </h3>
          <div class="event-list">
            {events.map(event => (
              <div class={`event ${event.featured ? 'featured' : ''}`} data-cat={event.cat}>
                <div class="when">
                  {formatEventDays(event)}
                  <small>{isDateRange(event) ? `– ${new Date(event.end).getDate().toString().padStart(2, '0')}` : getEventDayName(event, lang)}</small>
                </div>
                <div class="meta">
                  <span class="cat">{catLabels[lang][event.cat]}</span>
                  <h3 set:html={getEventName(event, lang).replace('·', '<em>·</em>')} />
                  <p class="desc">{getEventDesc(event, lang)}</p>
                </div>
                <div class="place" set:html={getEventPlace(event, lang).split('·').slice(0, 2).join('<br>')} />
                <span class={`badge ${event.cat === 'masterclass' ? 'secondary' : ''}`}>{getBadgeText(event)}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="cta-block">
    <div class="bg" style="background-image:url('/assets/hero-climb.jpg')"></div>
    <div class="inner">
      <div class="eyebrow reveal" style="color:var(--bone-3)"><span class="num" style="color:var(--accent-hi)">02 —</span><span>Sign up</span></div>
      <h2 class="h-hero reveal">Want to join<br><em class="serif">us</em><span class="dot">.</span></h2>
      <p class="reveal">Talk to any coach or write to us. We'll explain how to sign up and who you'll be going with.</p>
      <div class="actions reveal">
        <a class="btn-primary" href="/en/contacte">Sign me up<span class="arr"></span></a>
        <a class="btn-ghost" href="https://wa.me/34629066531" target="_blank" rel="noopener">WhatsApp</a>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    (function(){
      var currentFilter='all';
      var filtersEl = document.getElementById('cat-filters');
      if (filtersEl) {
        filtersEl.addEventListener('click', function(e){
          var target = e.target as HTMLElement;
          var b = target.closest('.cat-filter') as HTMLElement;
          if(!b) return;
          document.querySelectorAll('.cat-filter').forEach(function(x){x.classList.remove('on');});
          b.classList.add('on');
          currentFilter = b.dataset.f || 'all';
          document.querySelectorAll('.event').forEach(function(ev){
            var el = ev as HTMLElement;
            var c = el.dataset.cat;
            el.classList.toggle('hidden', currentFilter!=='all' && c!==currentFilter);
          });
          document.querySelectorAll('.month-band').forEach(function(m){
            var el = m as HTMLElement;
            var visible = el.querySelectorAll('.event:not(.hidden)').length > 0;
            el.style.display = visible ? '' : 'none';
          });
        });
      }
    })();
  </script>
</Layout>
