---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import Schema from '../../components/Schema.astro'
---

<Layout
  title="Weekly Schedule · CrossFit La Mola Terrassa"
  description="Weekly schedule at CrossFit Terrassa. Classes Monday to Sunday: WOD, weightlifting, hybrid, strength and more. Book via the Aimharder app."
  canonical="https://crossfitlamola.com/en/horari"
>
  <Schema type="horari" slot="head" />
  <Nav currentPage="/en/horari" />

  <section class="page-hero" id="main">
    <div class="bg" style="background-image:url('/assets/community-5.jpg')"></div>
    <div class="inner">
      <div class="crumb"><a href="/en">Home</a><span>/</span><span>Schedule</span></div>
      <div class="kicker"><span>Weekly</span><span class="bar"></span><span>Book via Aimharder</span></div>
      <h1>The week's<br><em class="serif">schedule</em><span class="dot">.</span></h1>
      <p class="sub">Monday to Thursday from 7:00 to 21:30. Friday from 7:00 to 20:30. Saturday and Sunday from 9:30 to 11:30. Book via the app.</p>
    </div>
  </section>

  <div class="status-strip">
    <div class="wrap">
      <span id="status"><span class="dot-live" id="statusDot"></span><span id="statusText">Open now</span></span>
      <span>Av. del Vallès 724C · Terrassa</span>
      <span>Mon-Thu 07:00-21:30 · Fri 07:00-20:30 · Sat-Sun 09:30-11:30</span>
      <span style="margin-left:auto;"><a href="https://wa.me/34629066531" style="color:var(--accent-ink);">WhatsApp &rarr;</a></span>
    </div>
  </div>

  <section class="sec bone" style="padding-top:clamp(64px,8vw,120px);">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">01 —</span><span>Weekly grid</span></div>
      <div style="height:16px"></div>
      <div class="sec-head">
        <h2 class="h-xl reveal">Every class,<br><em class="serif">every</em> time slot<span class="dot">.</span></h2>
        <p class="lead reveal">Filter by discipline. Coached classes have limited capacity. Book ahead, especially for morning and evening slots.</p>
      </div>

      <div class="toggle-row reveal">
        <label><input type="checkbox" id="showOpen"> Show Open Gym and Outdoor Open</label>
        <span style="opacity:.7;">By default you only see coached classes</span>
      </div>

      <div class="filters reveal" id="filters">
        <button class="filter on" data-f="all">All <span class="count" id="c-all"></span></button>
        <button class="filter" data-f="wod">WOD <span class="count" id="c-wod"></span></button>
        <button class="filter" data-f="wl">Weightlifting <span class="count" id="c-wl"></span></button>
        <button class="filter" data-f="hy">Hybrid <span class="count" id="c-hy"></span></button>
        <button class="filter" data-f="bw">Bodyweight <span class="count" id="c-bw"></span></button>
        <button class="filter" data-f="st">Strength Club <span class="count" id="c-st"></span></button>
        <button class="filter" data-f="ab">Abs &amp; Cals <span class="count" id="c-ab"></span></button>
        <button class="filter" data-f="pr">The Program <span class="count" id="c-pr"></span></button>
        <button class="filter" data-f="rc">Running <span class="count" id="c-rc"></span></button>
        <button class="filter" data-f="etc">Entrena con tu coach <span class="count" id="c-etc"></span></button>
      </div>

      <div class="week reveal" id="week"></div>

      <div class="legend reveal">
        <span class="chip" style="--c:var(--bone-ink);">WOD</span>
        <span class="chip" style="--c:var(--accent-ink);">Weightlifting · Program</span>
        <span class="chip" style="--c:#3d5f3f;">Hybrid</span>
        <span class="chip" style="--c:#8c3f2f;">Strength</span>
        <span class="chip" style="--c:#5a4a2f;">Bodyweight</span>
        <span class="chip" style="--c:#7a4a3a;">Abs &amp; Cals</span>
        <span class="chip" style="--c:#3a5a7a;">Running</span>
      </div>

      <div class="meta-card reveal">
        <strong>How to book:</strong> Download the <strong>Aimharder</strong> app and register with your code. You can book <strong>up to 24h in advance</strong>. If you've used your monthly quota, you can pay for <strong>extra classes at 8EUR/class</strong> or upgrade your plan.
      </div>
    </div>
  </section>

  <section class="cta-block">
    <div class="bg" style="background-image:url('/assets/class-program.webp')"></div>
    <div class="inner">
      <div class="eyebrow reveal" style="color:var(--bone-3)"><span class="num" style="color:var(--accent-hi)">02 —</span><span>First time?</span></div>
      <h2 class="h-hero reveal">Book<br>your <em class="serif">first</em><span class="dot">.</span></h2>
      <p class="reveal">If it's your first time, get in touch before and we'll set up a welcome session tailored to your level.</p>
      <div class="actions reveal">
        <a class="btn-primary" href="/en/contacte">Book first class<span class="arr"></span></a>
        <a class="btn-ghost" href="/en/classes">See disciplines</a>
      </div>
    </div>
  </section>

  <Footer />

  <style is:global>
    .status-strip{ padding:18px var(--page-pad); background:var(--bone-soft); color:var(--bone-ink); border-bottom:1px solid var(--line-ink);}
    .status-strip .wrap{ max-width:var(--max); margin:0 auto; display:flex; flex-wrap:wrap; gap:20px 32px; align-items:center; font-family:var(--f-mono); font-size:11px; letter-spacing:.2em; text-transform:uppercase;}
    .status-strip .dot-live{ width:8px; height:8px; background:#2f8f3f; border-radius:50%; display:inline-block; margin-right:10px; box-shadow:0 0 0 4px rgba(47,143,63,.15);}
    .status-strip .dot-live.closed{ background:#b85a3a; box-shadow:0 0 0 4px rgba(184,90,58,.15);}

    .filters{ display:flex; flex-wrap:wrap; gap:8px; margin:40px 0 32px;}
    .filter{ font-family:var(--f-mono); font-size:10.5px; letter-spacing:.2em; text-transform:uppercase; padding:10px 16px 9px; border:1px solid var(--line-ink-s); border-radius:999px; color:var(--bone-ink); opacity:.7; cursor:pointer; transition:all .2s; background:transparent;}
    .filter:hover{ opacity:1;}
    .filter.on{ background:var(--bone-ink); color:var(--bone); border-color:var(--bone-ink); opacity:1;}
    .filter .count{ margin-left:6px; opacity:.6;}

    .toggle-row{ display:flex; flex-wrap:wrap; gap:24px; align-items:center; margin-bottom:28px; font-family:var(--f-mono); font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--muted-ink);}
    .toggle-row label{ display:inline-flex; align-items:center; gap:10px; cursor:pointer;}
    .toggle-row input{ appearance:none; width:32px; height:18px; background:var(--line-ink-s); border-radius:999px; position:relative; transition:background .2s; cursor:pointer;}
    .toggle-row input::after{ content:""; position:absolute; top:2px; left:2px; width:14px; height:14px; background:var(--bone); border-radius:50%; transition:transform .2s; box-shadow:0 1px 2px rgba(0,0,0,.2);}
    .toggle-row input:checked{ background:var(--accent-ink);}
    .toggle-row input:checked::after{ transform:translateX(14px);}

    .week{ display:grid; grid-template-columns:1fr; gap:40px; margin-top:20px;}
    @media(min-width:1100px){ .week{ grid-template-columns:repeat(7,1fr); gap:1px; background:var(--line-ink); border:1px solid var(--line-ink); border-radius:2px; overflow:hidden;} }

    .day{ background:var(--bone); padding:24px 16px;}
    @media(min-width:1100px){ .day{ padding:14px 10px 20px;} }
    .day h4{ font-family:var(--f-display); font-weight:500; font-size:20px; letter-spacing:-0.02em; margin:0 0 2px; display:flex; align-items:baseline; gap:8px;}
    .day h4 .abbrev{ display:none;}
    @media(min-width:1100px){ .day h4 .full{ display:none;} .day h4 .abbrev{ display:inline;} }
    .day .date{ display:none; }
    .day.today h4{ color:var(--accent-ink);}
    .day.today h4::after{ content:"· today"; font-family:var(--f-serif); font-style:italic; font-size:14px; font-weight:400; margin-left:4px; letter-spacing:normal; text-transform:none; color:var(--accent-ink);}
    @media(min-width:1100px){ .day.today{ background:var(--bone-soft);} }

    .slot{ padding:10px 0; border-top:1px solid var(--line-ink); transition:background .15s; cursor:default; position:relative;}
    .slot:last-child{ border-bottom:1px solid var(--line-ink);}
    .slot.hidden{ display:none;}
    .slot .time{ font-family:var(--f-mono); font-size:11px; letter-spacing:.12em; color:var(--bone-ink); font-weight:500;}
    .slot .disc{ font-family:var(--f-display); font-weight:500; font-size:14px; letter-spacing:-0.005em; margin-top:3px; line-height:1.2;}
    .slot .extras{ font-family:var(--f-mono); font-size:9.5px; letter-spacing:.15em; text-transform:uppercase; color:var(--muted-ink); margin-top:4px; opacity:.7;}
    .slot.open-only{ opacity:.45;}
    .slot.open-only.always-visible{ opacity:1;}
    .slot.open-only .disc{ font-weight:300; font-style:italic; font-family:var(--f-display);}
    .slot.open-only.always-visible .disc{ font-style:normal; font-weight:500; color:var(--bone-ink);}

    .slot[data-disc*="wod"] .disc{ color:var(--bone-ink);}
    .slot[data-disc*="wl"] .disc{ color:var(--accent-ink);}
    .slot[data-disc*="hy"] .disc{ color:#3d5f3f;}
    .slot[data-disc*="st"] .disc{ color:#8c3f2f;}
    .slot[data-disc*="bw"] .disc{ color:#5a4a2f;}
    .slot[data-disc*="ab"] .disc{ color:#7a4a3a;}
    .slot[data-disc*="pr"] .disc{ color:var(--accent-ink); font-weight:500;}
    .slot[data-disc*="rc"] .disc{ color:#3a5a7a;}
    .slot[data-disc*="pr"]{ background:linear-gradient(to right, rgba(185,169,114,.1), transparent 60%); }

    .time-col{ display:none;}
    @media(min-width:1100px){
      .time-col{ display:block; background:var(--bone-soft); padding:60px 10px 20px; font-family:var(--f-mono); font-size:10px; letter-spacing:.15em; color:var(--muted-ink); text-transform:uppercase;}
      .time-col .row{ height:72px; border-top:1px dashed var(--line-ink); padding-top:6px; display:flex; align-items:flex-start;}
      .time-col .row:first-child{ border-top:none;}
    }

    .legend{ margin-top:48px; display:flex; flex-wrap:wrap; gap:16px 32px; padding-top:32px; border-top:1px solid var(--line-ink); font-family:var(--f-mono); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted-ink); align-items:center;}
    .legend span strong{ color:var(--bone-ink); font-weight:500;}
    .legend .chip{ display:inline-flex; align-items:center; gap:8px;}
    .legend .chip::before{ content:""; width:10px; height:10px; border-radius:2px; background:var(--c, var(--bone-ink));}

    .empty{ font-family:var(--f-serif); font-style:italic; font-size:14px; color:var(--muted-ink); padding:14px 0;}

    .meta-card{ background:var(--bone-soft); padding:20px 22px; margin:28px 0 0; border-left:2px solid var(--accent-ink); font-family:var(--f-serif); font-size:15.5px; line-height:1.55; color:var(--bone-ink);}
    .meta-card strong{ font-weight:500; letter-spacing:-0.005em;}
  </style>

  <script>
  (function(){
    function updateStatus(){
      var now=new Date(), d=now.getDay(), h=now.getHours()+now.getMinutes()/60;
      var open = (d>=1&&d<=5 && h>=7 && h<21.5) || (d===6 && h>=9.5 && h<11.5) || (d===0 && h>=9.5 && h<11.5);
      var dot=document.getElementById('statusDot'), t=document.getElementById('statusText');
      if (dot && t) {
        if (open){ dot.classList.remove('closed'); t.textContent='Open now'; }
        else { dot.classList.add('closed'); t.textContent='Closed now'; }
      }
    }
    updateStatus(); setInterval(updateStatus, 60000);

    var SCHEDULE = {
      "Monday": [
        ["07:00-08:00", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["08:00-09:00", ["OPEN", "OPEN EXTERIOR"]],
        ["09:30-10:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["10:30-11:30", ["HYBRID CLUB", "OPEN", "OPEN EXTERIOR"]],
        ["11:30-12:30", ["OPEN", "OPEN EXTERIOR"]],
        ["12:30-13:30", ["OPEN", "OPEN EXTERIOR"]],
        ["13:30-14:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["14:30-15:30", ["OPEN", "OPEN EXTERIOR"]],
        ["15:30-16:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["16:30-17:30", ["OPEN", "OPEN EXTERIOR"]],
        ["17:30-18:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["18:30-19:30", ["HYBRID CLUB", "OPEN EXTERIOR"]],
        ["18:30-20:30", ["THE PROGRAM"]],
        ["19:30-20:30", ["WOD", "OPEN EXTERIOR"]],
        ["20:30-21:30", ["WOD", "OPEN", "OPEN EXTERIOR"]]
      ],
      "Tuesday": [
        ["07:00-08:00", ["STRENGTH CLUB - POWERLIFTING", "OPEN", "OPEN EXTERIOR"]],
        ["08:00-09:00", ["OPEN", "OPEN EXTERIOR"]],
        ["09:30-10:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["10:30-11:30", ["HYBRID CLUB", "OPEN", "OPEN EXTERIOR"]],
        ["11:30-12:30", ["OPEN", "OPEN EXTERIOR"]],
        ["12:30-13:30", ["OPEN", "OPEN EXTERIOR"]],
        ["13:30-14:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["14:30-15:30", ["OPEN", "OPEN EXTERIOR"]],
        ["15:30-16:30", ["OPEN", "OPEN EXTERIOR"]],
        ["16:00-17:30", ["TRAIN WITH YOUR COACH"]],
        ["16:30-17:30", ["OPEN", "OPEN EXTERIOR"]],
        ["17:30-18:30", ["WOD", "BODYWEIGHT LAB - ADVANCE", "OPEN EXTERIOR"]],
        ["18:30-19:30", ["WOD", "OPEN EXTERIOR"]],
        ["19:30-20:30", ["HYBRID CLUB", "OPEN EXTERIOR"]],
        ["20:30-21:30", ["STRENGTH CLUB - POWERLIFTING", "OPEN", "OPEN EXTERIOR"]]
      ],
      "Wednesday": [
        ["07:00-08:00", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["08:00-09:00", ["OPEN", "OPEN EXTERIOR"]],
        ["09:30-10:30", ["LA MOLA WEIGHTLIFTING", "OPEN", "OPEN EXTERIOR"]],
        ["10:30-11:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["11:30-12:30", ["OPEN", "OPEN EXTERIOR"]],
        ["12:30-13:30", ["OPEN", "OPEN EXTERIOR"]],
        ["13:30-14:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["14:30-15:30", ["OPEN", "OPEN EXTERIOR"]],
        ["15:30-16:30", ["OPEN", "OPEN EXTERIOR"]],
        ["16:00-17:30", ["TRAIN WITH YOUR COACH"]],
        ["16:30-17:30", ["OPEN", "OPEN EXTERIOR"]],
        ["17:30-18:30", ["WOD", "LA MOLA WEIGHTLIFTING", "OPEN EXTERIOR"]],
        ["18:30-19:30", ["WOD", "BODYWEIGHT LAB - BASE", "RUNNING CLUB", "OPEN EXTERIOR"]],
        ["18:30-20:30", ["THE PROGRAM"]],
        ["19:30-20:30", ["WOD", "ABS & CALS", "OPEN EXTERIOR"]],
        ["20:30-21:30", ["WOD", "OPEN", "OPEN EXTERIOR"]]
      ],
      "Thursday": [
        ["07:00-08:00", ["HYBRID CLUB", "OPEN", "OPEN EXTERIOR"]],
        ["08:00-09:00", ["OPEN", "OPEN EXTERIOR"]],
        ["09:30-10:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["10:30-11:30", ["ABS & CALS", "OPEN", "OPEN EXTERIOR"]],
        ["11:30-12:30", ["OPEN", "OPEN EXTERIOR"]],
        ["12:30-13:30", ["OPEN", "OPEN EXTERIOR"]],
        ["13:30-14:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["14:30-15:30", ["OPEN", "OPEN EXTERIOR"]],
        ["15:30-16:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["16:00-17:30", ["TRAIN WITH YOUR COACH"]],
        ["16:30-17:30", ["OPEN", "OPEN EXTERIOR"]],
        ["17:30-18:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["18:30-19:30", ["HYBRID CLUB", "OPEN EXTERIOR"]],
        ["19:30-20:30", ["WOD", "OPEN EXTERIOR"]],
        ["20:30-21:30", ["WOD", "OPEN", "OPEN EXTERIOR"]]
      ],
      "Friday": [
        ["07:00-08:00", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["08:00-09:00", ["OPEN", "OPEN EXTERIOR"]],
        ["09:30-10:30", ["STRENGTH CLUB - POWERLIFTING", "OPEN", "OPEN EXTERIOR"]],
        ["10:30-11:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["11:30-12:30", ["OPEN", "OPEN EXTERIOR"]],
        ["12:30-13:30", ["OPEN", "OPEN EXTERIOR"]],
        ["13:30-14:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["14:30-15:30", ["OPEN", "OPEN EXTERIOR"]],
        ["15:30-16:30", ["OPEN", "OPEN EXTERIOR"]],
        ["16:30-17:30", ["OPEN", "OPEN EXTERIOR"]],
        ["17:30-18:30", ["STRENGTH CLUB - POWERLIFTING", "OPEN", "OPEN EXTERIOR"]],
        ["18:30-19:30", ["WOD", "OPEN", "OPEN EXTERIOR"]],
        ["18:30-20:30", ["THE PROGRAM"]],
        ["19:30-20:30", ["WOD", "OPEN", "OPEN EXTERIOR"]]
      ],
      "Saturday": [
        ["09:30-10:30", ["WOD IN PAIRS", "OPEN"]],
        ["10:30-11:30", ["WOD IN PAIRS", "OPEN"]]
      ],
      "Sunday": [
        ["09:30-10:30", ["OPEN", "OPEN EXTERIOR"]],
        ["10:30-11:30", ["OPEN", "OPEN EXTERIOR"]]
      ]
    };

    function classify(name){
      var n=name.toUpperCase();
      if (n==='OPEN' || n==='OPEN EXTERIOR') return {k:'open', l:n, interior:n==='OPEN'};
      if (n==='ENTRENA CON TU COACH') return {k:'etc', l:'Entrena con tu coach'};
      if (n.indexOf('THE PROGRAM')>=0) return {k:'pr', l:'The Program'};
      if (n.indexOf('WEIGHTLIFTING')>=0) return {k:'wl', l:'Weightlifting'};
      if (n.indexOf('HYBRID')>=0) return {k:'hy', l:'Hybrid Club'};
      if (n.indexOf('STRENGTH')>=0) return {k:'st', l:'Strength · Powerlifting'};
      if (n.indexOf('BODYWEIGHT')>=0) return {k:'bw', l:n.indexOf('ADVANCE')>=0?'Bodyweight Lab · Advance':'Bodyweight Lab · Base'};
      if (n.indexOf('ABS')>=0) return {k:'ab', l:'Abs & Cals'};
      if (n.indexOf('RUNNING')>=0 || n.indexOf('RUN BY')>=0) return {k:'rc', l:n.indexOf('BEACH')>=0?'Run + Brunch + Beach':'Running Club'};
      if (n.indexOf('WOD IN PAIRS')>=0) return {k:'wod', l:'Partner WOD'};
      if (n.indexOf('WOD')>=0) return {k:'wod', l:'WOD'};
      return {k:'wod', l:name};
    }

    var days=['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
    var abbr=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
    var monday=new Date(); var day=monday.getDay(); var diff=(day===0?-6:1-day); monday.setDate(monday.getDate()+diff);
    var today=new Date(); today.setHours(0,0,0,0);
    var fmt=function(d){ return d.getDate()+' '+['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()];};
    document.querySelectorAll('.js-week-range').forEach(function(el){ var s=new Date(monday); var e=new Date(monday); e.setDate(e.getDate()+6); el.textContent = fmt(s)+' - '+fmt(e); });

    var counts={all:0,wod:0,wl:0,hy:0,bw:0,st:0,ab:0,pr:0,rc:0,etc:0};
    var week=document.getElementById('week');

    if (week) {
      days.forEach(function(dname, i){
        var d=new Date(monday); d.setDate(d.getDate()+i);
        var isToday=(d.getTime()===today.getTime());
        var div=document.createElement('div'); div.className='day'+(isToday?' today':'');
        div.innerHTML='<h4><span class="full">'+dname+'</span><span class="abbrev">'+abbr[i]+'</span></h4>';

        var slots=SCHEDULE[dname]||[];
        var dayHasCoached = slots.some(function(entry){
          return entry[1].some(function(c){ return classify(c).k !== 'open'; });
        });
        if (!slots.length){
          div.innerHTML += '<p class="empty">Rest day · no classes</p>';
        } else {
          slots.forEach(function(entry){
            var time=entry[0], arr=entry[1];
            var coached=[], opens=[];
            arr.forEach(function(c){ var r=classify(c); if(r.k==='open') opens.push(r); else coached.push(r); });

            if (!coached.length && !opens.length) return;

            if (coached.length){
              coached.forEach(function(r){
                counts.all++; if(counts[r.k]!==undefined) counts[r.k]++;
                var extras='';
                if (opens.length) extras='+ Open'+(opens.some(function(o){return !o.interior;})?' · Outdoor':'');
                var el=document.createElement('div');
                el.className='slot';
                el.setAttribute('data-disc', r.k);
                el.innerHTML='<div class="time">'+time+'</div><div class="disc">'+r.l+'</div>'+(extras?'<div class="extras">'+extras+'</div>':'');
                div.appendChild(el);
              });
            } else if (opens.length){
              var label=opens.map(function(o){return o.l==='OPEN EXTERIOR'?'Open Exterior':'Open';}).join(' - ');
              var el=document.createElement('div');
              el.className='slot open-only' + (dayHasCoached ? '' : ' always-visible');
              el.setAttribute('data-disc', 'open');
              el.innerHTML='<div class="time">'+time+'</div><div class="disc">'+label+'</div>';
              div.appendChild(el);
            }
          });
        }
        week.appendChild(div);
      });
    }

    Object.keys(counts).forEach(function(k){ var el=document.getElementById('c-'+k); if(el) el.textContent='· '+counts[k]; });

    var currentFilter='all';
    var filtersEl = document.getElementById('filters');
    if (filtersEl) {
      filtersEl.addEventListener('click', function(e){
        var b=e.target.closest('.filter'); if(!b) return;
        document.querySelectorAll('.filter').forEach(function(x){x.classList.remove('on');});
        b.classList.add('on');
        currentFilter=b.dataset.f;
        applyFilter();
      });
    }

    var showOpen=false;
    var showOpenEl = document.getElementById('showOpen');
    if (showOpenEl) {
      showOpenEl.addEventListener('change', function(e){
        showOpen=e.target.checked;
        applyFilter();
      });
    }

    function applyFilter(){
      document.querySelectorAll('.slot').forEach(function(s){
        var d=s.dataset.disc;
        var isOpen=(d==='open');
        var alwaysVisible=s.classList.contains('always-visible');
        var matchFilter = (currentFilter==='all') || (d===currentFilter);
        var visible = matchFilter && (!isOpen || showOpen || alwaysVisible);
        s.classList.toggle('hidden', !visible);
      });
    }
    applyFilter();
  })();
  </script>
</Layout>
