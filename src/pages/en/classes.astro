        {"@type":"ListItem","position":6,"item":{"@id":"https://crossfitlamola.com/en/classes#abs-cals","url":"https://crossfitlamola.com/en/classes#abs-cals","image":"https://crossfitlamola.com/assets/class-abs.webp",
          "@type":"Course","name":"Abs & Cals","description":"Specific abdominal work and ergometer interval training (rower, bike erg, ski erg) to improve core and cardiovascular capacity.",
