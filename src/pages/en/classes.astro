---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import Schema from '../../components/Schema.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
---

<Layout
  title="Classes · CrossFit La Mola Terrassa"
  description="8 disciplines in Terrassa: WOD, weightlifting, hybrid training, running club, strength and more. Coached classes for all levels."
>
  <Schema type="classes" slot="head" />
  <Breadcrumb items={[{name: "Classes"}]} lang="en" slot="head" />
  <Fragment slot="head">
    <script type="application/ld+json" data-schema="itemlist-disciplines" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Disciplines at CrossFit La Mola",
      "itemListElement": [
        {"@type":"ListItem","position":1,"item":{"@id":"https://crossfitlamola.com/en/classes#wod","url":"https://crossfitlamola.com/en/classes#wod","image":"https://crossfitlamola.com/assets/class-wod.webp",
          "@type":"Course","name":"WOD (Workout of the Day)","description":"Daily coached class combining strength, basic weightlifting, gymnastics and high-intensity cardiovascular conditioning. Scalable to all levels.",
          "provider":{"@id":"https://crossfitlamola.com/#organization"},
          "inLanguage":"en","educationalLevel":"Beginner to Advanced","timeRequired":"PT60M",
          "audience":{"@type":"EducationalAudience","audienceType":"People who want to improve overall fitness, from beginners to advanced athletes"},
          "teaches":["Functional movements","Basic weightlifting","Basic gymnastics","Cardiovascular conditioning","EMOM, AMRAP and FOR TIME"],
          "hasCourseInstance":{"@type":"CourseInstance","courseMode":"Onsite","location":{"@id":"https://crossfitlamola.com/#organization"}},
          "offers":{"@type":"Offer","category":"First class free","price":"0","priceCurrency":"EUR"}
        }},
        {"@type":"ListItem","position":2,"item":{"@id":"https://crossfitlamola.com/en/classes#weightlifting","url":"https://crossfitlamola.com/en/classes#weightlifting","image":"https://crossfitlamola.com/assets/class-weightlifting.webp",
          "@type":"Course","name":"La Mola Weightlifting","description":"Olympic weightlifting: snatch and clean & jerk technique with progressive loads and specific mobility.",
          "provider":{"@id":"https://crossfitlamola.com/#organization"},
          "inLanguage":"en","educationalLevel":"All Levels","timeRequired":"PT60M",
          "audience":{"@type":"EducationalAudience","audienceType":"People who want to improve Olympic weightlifting technique"},
          "teaches":["Snatch","Clean & jerk","Olympic positions and mobility","Technical efficiency"],
          "coursePrerequisites":"None (previous experience recommended)",
          "hasCourseInstance":{"@type":"CourseInstance","courseMode":"Onsite","location":{"@id":"https://crossfitlamola.com/#organization"}}
        }},
        {"@type":"ListItem","position":3,"item":{"@id":"https://crossfitlamola.com/en/classes#strength","url":"https://crossfitlamola.com/en/classes#strength","image":"https://crossfitlamola.com/assets/class-strength.webp",
          "@type":"Course","name":"Strength Club - Powerlifting","description":"Structured strength cycles with barbell: squat, bench press, deadlift and press, with accessories.",
          "provider":{"@id":"https://crossfitlamola.com/#organization"},
          "inLanguage":"en","educationalLevel":"All Levels","timeRequired":"PT60M",
          "audience":{"@type":"EducationalAudience","audienceType":"People who want to increase maximum strength with barbell"},
          "teaches":["Back squat","Bench press","Deadlift","Press","Bar technique","Progressive strength cycles"],
          "hasCourseInstance":{"@type":"CourseInstance","courseMode":"Onsite","location":{"@id":"https://crossfitlamola.com/#organization"}}
        }},
        {"@type":"ListItem","position":4,"item":{"@id":"https://crossfitlamola.com/en/classes#bodyweight","url":"https://crossfitlamola.com/en/classes#bodyweight","image":"https://crossfitlamola.com/assets/class-bodyweight.webp",
          "@type":"Course","name":"Bodyweight Lab (Base and Advanced)","description":"Gymnastics in two tracks. Base: fundamentals like strict pull-up, handstand hold and beginner progressions. Advanced: butterfly pull-ups, muscle-ups, handstand walk (HSW) and handstand push-ups (HSPU).",
          "provider":{"@id":"https://crossfitlamola.com/#organization"},
          "inLanguage":"en","educationalLevel":"Beginner to Advanced","timeRequired":"PT45M",
          "audience":{"@type":"EducationalAudience","audienceType":"People who want to learn gymnastics from scratch (Base) or master advanced movements (Advanced)"},
          "teaches":["Strict pull-up","Handstand hold","Butterfly pull-ups","Muscle-ups","Handstand walk","HSPU","Body control","Relative strength"],
          "hasCourseInstance":{"@type":"CourseInstance","courseMode":"Onsite","location":{"@id":"https://crossfitlamola.com/#organization"}}
        }},
        {"@type":"ListItem","position":5,"item":{"@id":"https://crossfitlamola.com/en/classes#hybrid","url":"https://crossfitlamola.com/en/classes#hybrid","image":"https://crossfitlamola.com/assets/class-hybrid.webp",
          "@type":"Course","name":"Hybrid Club","description":"Hybrid training with sled push/pull, ergometers (rower, ski erg), wall balls, kettlebells and running intervals.",
          "provider":{"@id":"https://crossfitlamola.com/#organization"},
          "inLanguage":"en","educationalLevel":"All Levels","timeRequired":"PT60M",
          "audience":{"@type":"EducationalAudience","audienceType":"People who want to combine endurance and functional strength with hybrid formats"},
          "teaches":["Sled push","Sled pull","Ski erg","Concept2 row","Wall balls","Kettlebells","Hybrid format"],
