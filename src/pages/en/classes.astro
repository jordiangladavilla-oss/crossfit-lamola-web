          "teaches":["Core work","Ergometer intervals","Stability","Cardiovascular endurance"],
          "hasCourseInstance":{"@type":"CourseInstance","courseMode":"Onsite","location":{"@id":"https://crossfitlamola.com/#organization"}}
        }},
        {"@type":"ListItem","position":7,"item":{"@id":"https://crossfitlamola.com/en/classes#the-program","url":"https://crossfitlamola.com/en/classes#the-program","image":"https://crossfitlamola.com/assets/class-program.webp",
          "@type":"Course","name":"The Program","description":"Cycle-based structured programming for advanced athletes: competitive strategy, advanced methods and RX preparation.",
          "provider":{"@id":"https://crossfitlamola.com/#organization"},
          "inLanguage":"en","educationalLevel":"Advanced","timeRequired":"PT90M",
          "audience":{"@type":"EducationalAudience","audienceType":"Experienced athletes who want high-performance structured training"},
          "teaches":["Cycle-based programming","Competitive strategy","Advanced RX methods","Competition preparation"],
          "coursePrerequisites":"Minimum 1 year of CrossFit experience and mastery of basic movements",
          "hasCourseInstance":{"@type":"CourseInstance","courseMode":"Onsite","location":{"@id":"https://crossfitlamola.com/#organization"}}
        }},
        {"@type":"ListItem","position":8,"item":{"@id":"https://crossfitlamola.com/en/classes#running","url":"https://crossfitlamola.com/en/classes#running","image":"https://crossfitlamola.com/assets/class-running.webp",
          "@type":"Course","name":"Running Club","description":"Group running training: fartlek, intervals, long runs and running technique. Does not consume membership credit.",
          "provider":{"@id":"https://crossfitlamola.com/#organization"},
          "inLanguage":"en","educationalLevel":"All Levels","timeRequired":"PT60M",
          "audience":{"@type":"EducationalAudience","audienceType":"People who want to run in a group, improve performance and enjoy community"},
          "teaches":["Fartlek","Intervals","Long runs","Running technique"],
          "hasCourseInstance":{"@type":"CourseInstance","courseMode":"Onsite","location":{"@id":"https://crossfitlamola.com/#organization"}},
          "offers":{"@type":"Offer","category":"Free with membership","price":"0","priceCurrency":"EUR","description":"Does not consume membership credit"}
        }}
      ]
    })} />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {"@type": "Question", "name": "What is functional training?", "acceptedAnswer": {"@type": "Answer", "text": "Functional training works natural movements (pushing, pulling, lifting, carrying and running) to improve your overall fitness and everyday life. At CrossFit La Mola, in Terrassa, it's the foundation of every class: the WOD, weightlifting, hybrid work and gymnastics combine functional strength and conditioning for all levels."}},
        {"@type": "Question", "name": "Can I do the WOD if it's my first day?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. The coach scales all movements to your level and accompanies you throughout the session."}},
        {"@type": "Question", "name": "How long does a WOD last?", "acceptedAnswer": {"@type": "Answer", "text": "The class lasts 60 minutes: warm-up, technique or strength part, metcon and cool down."}},
        {"@type": "Question", "name": "Do I need to know weightlifting to sign up for Weightlifting class?", "acceptedAnswer": {"@type": "Answer", "text": "No. We start from scratch with an empty bar and build technique gradually."}},
        {"@type": "Question", "name": "Is lifting Olympic weight dangerous?", "acceptedAnswer": {"@type": "Answer", "text": "With correct technique and proper progression, no. The coach supervises every rep."}},
        {"@type": "Question", "name": "What level is needed for Hybrid Club?", "acceptedAnswer": {"@type": "Answer", "text": "Intermediate. It's ideal if you already have a CrossFit base and want to combine strength and endurance."}},
        {"@type": "Question", "name": "Is Hybrid Club good for Hyrox preparation?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, the programming follows a structure similar to Hyrox competition."}},
        {"@type": "Question", "name": "What's the difference between Bodyweight Lab Base and Advance?", "acceptedAnswer": {"@type": "Answer", "text": "Base works fundamentals like strict pull-up and handstand hold. Advance works butterfly, muscle-ups and HSW."}},
        {"@type": "Question", "name": "Can I move from Bodyweight Base to Advance?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, when the coach sees you've mastered the fundamentals you can move to advanced level."}},
        {"@type": "Question", "name": "Can I combine Strength Club with the WOD?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. Many athletes do Strength Club and then WOD on the same day."}},
        {"@type": "Question", "name": "What movements are worked in Strength Club?", "acceptedAnswer": {"@type": "Answer", "text": "Squat, deadlift, press and accessory variations for stability and core."}},
        {"@type": "Question", "name": "Can I do Abs & Cals without doing any other class?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, it's an independent 60-minute session you can do alone or combined with other classes."}},
        {"@type": "Question", "name": "Does Abs & Cals use credit from my plan?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, it counts as a regular class within your monthly plan."}},
        {"@type": "Question", "name": "Who can do The Program?", "acceptedAnswer": {"@type": "Answer", "text": "Advanced athletes who want to compete or take their performance to the highest level."}},
        {"@type": "Question", "name": "Is it mandatory to do all 4 sessions of The Program?", "acceptedAnswer": {"@type": "Answer", "text": "Not mandatory, but the programming is designed to be followed completely."}},
        {"@type": "Question", "name": "Do I need to be a good runner for Running Club?", "acceptedAnswer": {"@type": "Answer", "text": "No. There are paces for all levels and we always go as a group."}},
        {"@type": "Question", "name": "Does Running Club use credit from my plan?", "acceptedAnswer": {"@type": "Answer", "text": "No, Running Club doesn't use credit from your monthly plan."}},
        {"@type": "Question", "name": "What class is best to start CrossFit?", "acceptedAnswer": {"@type": "Answer", "text": "The WOD is the ideal class to start. It's the daily CrossFit class that combines all elements and adapts to any level. The coach scales movements according to your abilities."}},
        {"@type": "Question", "name": "Do I need previous experience for weightlifting?", "acceptedAnswer": {"@type": "Answer", "text": "No. Weightlifting classes are designed to learn from scratch. We start with basic technique and progress gradually."}},
        {"@type": "Question", "name": "What is Hybrid Training?", "acceptedAnswer": {"@type": "Answer", "text": "Hybrid Training combines CrossFit elements with endurance training (running, bike, rowing). Ideal for those who want to prepare for mixed competitions or improve their endurance."}},
        {"@type": "Question", "name": "Can I do just one discipline or do I have to do them all?", "acceptedAnswer": {"@type": "Answer", "text": "You can choose the classes you like best. All plans include access to all disciplines, but there's no obligation to do them all."}},
        {"@type": "Question", "name": "How many days a week should I come?", "acceptedAnswer": {"@type": "Answer", "text": "We recommend 3-4 days per week to see results. But everyone is different: we listen to your body and adapt the frequency."}}
      ]
    }
    </script>
    <style>
      .disc-list{ margin-top: 60px; border-top: 1px solid var(--line-ink-s); }
      .disc{
        display:grid; grid-template-columns:1fr; gap:24px;
        padding: clamp(28px,3.5vw,52px) 0;
        border-bottom: 1px solid var(--line-ink-s);
        align-items: start;
      }
      @media(min-width:900px){
        .disc{ grid-template-columns: 80px 1.1fr 1fr 0.9fr; gap:40px; align-items:center; }
      }
      .disc .num{ font-family:var(--f-mono); font-size:11px; letter-spacing:.22em; color:var(--accent-ink); }
      .disc h3{ font-family:var(--f-display); font-weight:500; font-size:clamp(30px,4.2vw,56px); letter-spacing:-0.03em; line-height:.96; margin:0;}
      .disc h3 em{ font-family:var(--f-serif); font-style:italic; font-weight:300; color:var(--accent-ink);}
      .disc .tagline{ font-family:var(--f-mono); font-size:11px; letter-spacing:.2em; text-transform:uppercase; color:var(--muted-ink); margin-top:10px;}
      .disc p{ font-family:var(--f-serif); font-size:17px; line-height:1.5; color:var(--bone-ink); opacity:.78; margin:0; max-width:42ch;}
      .disc .meta{ display:grid; gap:6px; font-family:var(--f-mono); font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--muted-ink);}
      .disc .meta strong{ color:var(--bone-ink); font-weight:500; letter-spacing:.14em;}
      .disc-more{ grid-column:1/-1; margin-top:18px;}
      .disc-more summary{ list-style:none; cursor:pointer; font-family:var(--f-mono); font-size:10.5px; letter-spacing:.22em; text-transform:uppercase; color:var(--accent-ink); display:inline-flex; align-items:center; gap:10px; padding:6px 0; user-select:none; transition:opacity .2s;}
      .disc-more summary::-webkit-details-marker{ display:none;}
      .disc-more summary:hover{ opacity:.7;}
      .disc-more summary:focus-visible{ outline:1px dashed var(--accent-ink); outline-offset:4px; border-radius:2px;}
      .disc-more-label::before{ content:"View ";}
      .disc-more[open] .disc-more-label::before{ content:"Hide ";}
      .disc-more-icon{ width:12px; height:12px; position:relative; display:inline-block;}
      .disc-more-icon::before,.disc-more-icon::after{ content:""; position:absolute; background:currentColor; transition:transform .25s ease;}
      .disc-more-icon::before{ left:0; right:0; top:50%; height:1.5px; transform:translateY(-50%);}
      .disc-more-icon::after{ top:0; bottom:0; left:50%; width:1.5px; transform:translateX(-50%);}
      .disc-more[open] .disc-more-icon::after{ transform:translateX(-50%) scaleY(0);}
      .disc-details{ margin:20px 0 0; padding-top:18px; border-top:1px dashed var(--line-ink-s); display:grid; gap:16px;}
      @media(min-width:900px){ .disc-details{ grid-template-columns:repeat(2,1fr); gap:16px 40px;} }
      .disc-details dt{ font-family:var(--f-mono); font-size:10px; letter-spacing:.22em; text-transform:uppercase; color:var(--accent-ink); font-weight:500; margin:0 0 5px;}
      .disc-details dd{ margin:0; font-family:var(--f-serif); font-size:14.5px; line-height:1.5; color:var(--bone-ink); opacity:.85;}
      .disc-details dd strong{ color:var(--bone-ink); font-weight:500; opacity:1;}
      .disc .thumb{ display:none;}
      @media(min-width:900px){
        .disc .thumb{ display:block; aspect-ratio:3/2; overflow:hidden; background:var(--ink-2);}
        .disc .thumb img{ width:100%; height:100%; object-fit:cover; filter:saturate(.9) contrast(1.02); transition:transform 1.2s cubic-bezier(.2,.8,.2,1);}
        .disc:hover .thumb img{ transform:scale(1.04);}
      }

      /* Path section */
      .path{ display:grid; gap:0; margin-top:60px; border-top:1px solid var(--line);}
      .path > div{ display:grid; grid-template-columns:1fr; gap:12px; padding:28px 0; border-bottom:1px solid var(--line); align-items:start;}
      @media(min-width:760px){ .path > div{ grid-template-columns:120px 1.2fr 2fr; gap:40px; align-items:center;} }
      .path .when{ font-family:var(--f-mono); font-size:11px; letter-spacing:.2em; color:var(--accent-hi); text-transform:uppercase;}
      .path h4{ font-family:var(--f-display); font-weight:500; font-size:clamp(20px,2.6vw,32px); letter-spacing:-0.025em; margin:0;}
      .path p{ font-family:var(--f-serif); font-size:16px; line-height:1.5; color:var(--bone-2); margin:0;}

      .foot-col--thin a, .foot-col--thin p{ font-weight:300 !important; letter-spacing:.002em; }
      @media(min-width: 760px){ .foot-top{ grid-template-columns: 1.2fr 1fr 1fr 1fr 1fr !important; } }
    </style>
  </Fragment>

  <Nav currentPage="/en/classes" />

  <section class="page-hero" id="main">
    <div class="bg" style="background-image:url('/assets/detail-rope.jpg')"></div>
    <div class="inner">
      <div class="crumb"><a href="/en">Home</a><span>/</span><span>Classes</span></div>
      <div class="kicker"><span>8 disciplines</span><span class="bar"></span><span>One purpose</span></div>
      <h1>Find your<br><em class="serif">flow</em><span class="dot">.</span></h1>
      <p class="sub">Training is not repeating, but building with technique, load and head. Each session is designed to make you progress with purpose, adapting to your moment and your level.</p>
    </div>
  </section>

  <section class="sec bone">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num"></span><span>The 8 disciplines</span></div>
      <div style="height:24px"></div>
      <div class="sec-head">
        <h2 class="h-xl reveal">Eight ways<br>to walk through the <em class="serif">door</em><span class="dot">.</span></h2>
        <p class="lead reveal">Every class has its purpose: one to build raw strength, another to find rhythm, another to sharpen technique. You don't have to pick just one.</p>
      </div>

      <div class="disc-list reveal-stagger">
        <article class="disc" id="wod" style="--i:0">
          <span class="num">01</span>
          <div><h3>WOD <em>(Workout of the Day)</em></h3><div class="tagline">Main class - 60 min</div></div>
          <p>The heart of CrossFit. Warm-up, skill work, WOD, and cool-down. A coach guides the group from start to finish.</p>
          <div class="meta"><span>Level <strong>All</strong></span><span>Frequency <strong>Daily</strong></span></div>
          <details class="disc-more"><summary><span class="disc-more-label">details</span><span class="disc-more-icon" aria-hidden="true"></span></summary><dl class="disc-details">
            <div><dt>Who it's for</dt><dd>People who want to improve overall fitness, from beginners to advanced athletes. Fully scalable.</dd></div>
            <div><dt>Class structure</dt><dd>Initial briefing and scaling options → guided warm-up (5-10 min) → strength or technique block (15-20 min) → main high-intensity workout (8-15 min) with EMOM, AMRAP or FOR TIME format → cool-down and stretching.</dd></div>
            <div><dt>What you learn</dt><dd>Functional movements, basic weightlifting, gymnastics and cardiovascular conditioning.</dd></div>
            <div><dt>What you gain</dt><dd>Overall fitness improvement, more energy, injury prevention, coordination and general wellbeing.</dd></div>
            <div><dt>What to bring</dt><dd>Sportswear, training shoes and water. <strong>Prerequisites:</strong> None.</dd></div>
          </dl></details>
        </article>

        <article class="disc" id="weightlifting" style="--i:1">
          <span class="num">02</span>
          <div><h3>Weightlifting</h3><div class="tagline">Snatch - Clean - Jerk - 60 min</div></div>
          <p>Olympic lifting. We work both lifts and their variations with progressions tailored to each athlete.</p>
          <div class="meta"><span>Level <strong>All</strong></span><span>Frequency <strong>2x/week</strong></span></div>
          <details class="disc-more"><summary><span class="disc-more-label">details</span><span class="disc-more-icon" aria-hidden="true"></span></summary><dl class="disc-details">
            <div><dt>Who it's for</dt><dd>People who want to improve Olympic weightlifting technique.</dd></div>
            <div><dt>Structure</dt><dd>Technical work with light to moderate loads and specific movement progressions.</dd></div>
            <div><dt>What you learn</dt><dd>Snatch, clean &amp; jerk, positions and Olympic-specific mobility.</dd></div>
            <div><dt>What you gain</dt><dd>Better technique, more efficiency and transfer to sports performance.</dd></div>
            <div><dt>What to bring</dt><dd>Sportswear, weightlifting shoes (recommended). <strong>Prerequisites:</strong> None (previous experience recommended).</dd></div>
          </dl></details>
        </article>

        <article class="disc" id="hybrid" style="--i:2">
          <span class="num">03</span>
          <div><h3>Hybrid Club</h3><div class="tagline">Strength + Cardio - 60 min</div></div>
          <p>Functional strength and long-distance cardiovascular endurance with simple movements: sled push/pull, row, ski erg, kettlebells and wall balls. Hybrid format, without complex technical movements.</p>
          <div class="meta"><span>Level <strong>All levels</strong></span><span>Frequency <strong>4x/week</strong></span></div>
          <details class="disc-more"><summary><span class="disc-more-label">details</span><span class="disc-more-icon" aria-hidden="true"></span></summary><dl class="disc-details">
            <div><dt>Who it's for</dt><dd>People who want to combine endurance and functional strength with hybrid formats.</dd></div>
            <div><dt>What you learn</dt><dd>Sled push/pull work, ergometers (row, ski erg), wall balls, kettlebells and running intervals.</dd></div>
            <div><dt>What you gain</dt><dd>High cardiovascular endurance, sustained strength and preparation for long efforts.</dd></div>
            <div><dt>What to bring</dt><dd>Sportswear, well-cushioned shoes. <strong>Prerequisites:</strong> None.</dd></div>
          </dl></details>
        </article>

        <article class="disc" id="bodyweight" style="--i:3">
          <span class="num">04</span>
          <div><h3>Bodyweight Lab</h3><div class="tagline">Gymnastics - 45 min</div></div>
          <p>Two tracks: Base for learning gymnastics fundamentals, and Advanced for butterfly pull-ups, muscle-ups, HSW and HSPU.</p>
          <div class="meta"><span>Level <strong>Base / Advanced</strong></span><span>Frequency <strong>2x/week</strong></span></div>
          <details class="disc-more"><summary><span class="disc-more-label">details</span><span class="disc-more-icon" aria-hidden="true"></span></summary><dl class="disc-details">
            <div><dt>Who it's for</dt><dd><strong>Base:</strong> gymnastics fundamentals (pull-up, handstand hold). <strong>Advanced:</strong> experienced athletes (muscle-up, HSPU, handstand walk).</dd></div>
            <div><dt>What you learn</dt><dd>Body control, gymnastic technique and progressions tailored to each level.</dd></div>
            <div><dt>What you gain</dt><dd>Relative strength, coordination and body mastery.</dd></div>
            <div><dt>What to bring</dt><dd>Sportswear.</dd></div>
          </dl></details>
        </article>

        <article class="disc" id="strength" style="--i:4">
          <span class="num">05</span>
          <div><h3>Strength Club</h3><div class="tagline">Powerlifting - 60 min</div></div>
          <p>Structured barbell strength cycle: squat, bench, deadlift, press. Heavy lifting, smart programming, proper rest.</p>
          <div class="meta"><span>Level <strong>All</strong></span><span>Frequency <strong>2x/week</strong></span></div>
          <details class="disc-more"><summary><span class="disc-more-label">details</span><span class="disc-more-icon" aria-hidden="true"></span></summary><dl class="disc-details">
            <div><dt>Who it's for</dt><dd>People who want to increase maximum strength with barbell.</dd></div>
            <div><dt>Structure</dt><dd>Strength cycles with accessories to correct imbalances.</dd></div>
            <div><dt>What you learn</dt><dd>Squat, bench press, deadlift and press, with technique and structured progression.</dd></div>
            <div><dt>What you gain</dt><dd>Pure strength, stability and control under load.</dd></div>
            <div><dt>What to bring</dt><dd>Sportswear, lifting belt (optional). <strong>Prerequisites:</strong> None.</dd></div>
          </dl></details>
        </article>

        <article class="disc" id="abs-cals" style="--i:5">
          <span class="num">06</span>
          <div><h3>Abs <em>&amp;</em> Cals</h3><div class="tagline">Core + cardio - 60 min</div></div>
          <p>Short, intense, designed to stack with another WOD or stand alone. Calories on the bike and core work.</p>
          <div class="meta"><span>Level <strong>All</strong></span><span>Frequency <strong>2x/week</strong></span></div>
