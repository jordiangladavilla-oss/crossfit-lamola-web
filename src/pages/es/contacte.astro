---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'

const title = "Contacto · CrossFit La Mola Terrassa"
const description = "CrossFit La Mola · Av. del Vallès 724C, Terrassa. WhatsApp 629 06 65 31. Lu–Ju 07:00–21:30, Vi 07:00–20:30. Primera clase gratis."
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <style>
      .contact-grid{ display:grid; grid-template-columns:1fr; gap:60px; margin-top:40px;}
      @media(min-width:900px){ .contact-grid{ grid-template-columns:1.1fr 0.9fr; gap:80px;} }

      .info-block{ display:grid; gap:0; border-top:1px solid var(--line);}
      .info-block > div{ padding:22px 0; border-bottom:1px solid var(--line);}
      .info-block .label{ font-family:var(--f-mono); font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:var(--muted); margin-bottom:8px;}
      .info-block .value{ font-family:var(--f-display); font-weight:500; font-size:clamp(20px,2vw,26px); letter-spacing:-0.02em;}
      .info-block .value a{ color:var(--bone);}
      .info-block .value a:hover{ color:var(--accent-hi);}
      .info-block .note{ font-family:var(--f-serif); font-size:15px; color:var(--bone-2); margin-top:4px;}

      .map{ aspect-ratio:16/10; background:var(--ink-2); position:relative; overflow:hidden; margin-top:60px; border-top:1px solid var(--line);}
      .map iframe{ width:100%; height:100%; border:0; filter:invert(.92) hue-rotate(180deg) saturate(.4) brightness(.85);}

      .visit-bar{ display:grid; grid-template-columns:1fr; gap:1px; margin-top:60px; background:var(--line-ink);}
      @media(min-width:760px){ .visit-bar{ grid-template-columns:repeat(3,1fr);} }
      .visit-bar > div{ background:var(--bone); padding:28px 24px;}
      .visit-bar h4{ font-family:var(--f-mono); font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:var(--accent-ink); margin:0 0 12px;}
      .visit-bar p{ font-family:var(--f-display); font-weight:500; font-size:clamp(17px,1.6vw,21px); letter-spacing:-0.015em; margin:0; line-height:1.3;}
      .visit-bar p em{ font-family:var(--f-serif); font-style:italic; font-weight:300;}

      .foot-col--thin a, .foot-col--thin p{ font-weight:300 !important; letter-spacing:.002em; }
      @media(min-width: 760px){ .foot-top{ grid-template-columns: 1.2fr 1fr 1fr 1fr 1fr !important; } }
    </style>
    <script type="application/ld+json" data-schema="base">
    {
      "@context": "https://schema.org",
      "@type": "ExerciseGym",
      "@id": "https://crossfitlamola.com/#organization",
      "name": "CrossFit La Mola",
      "alternateName": "La Mola CrossFit",
      "description": "Box de CrossFit en Terrassa desde 2025. Entrenamiento funcional, halterofilia, gimnástico y cardio con coaches certificados CF-L1 y CF-L2.",
      "url": "https://crossfitlamola.com/",
      "logo": "https://crossfitlamola.com/assets/logo-full.png",
      "image": "https://crossfitlamola.com/assets/hero-still.jpg",
      "telephone": "+34629066531",
      "email": "hola@crossfitlamola.com",
      "priceRange": "€€",
      "foundingDate": "2025",
      "currenciesAccepted": "EUR",
      "paymentAccepted": "Credit Card, Bank Transfer, Direct Debit, Virtual POS",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Avenida del Vallès 724 C",
        "postalCode": "08227",
        "addressLocality": "Terrassa",
        "addressRegion": "Cataluña",
        "addressCountry": "ES"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": "41.581285", "longitude": "2.027955" },
      "hasMap": "https://maps.app.goo.gl/LMWX4XfiVLq8PXxAA",
      "sameAs": [
        "https://www.instagram.com/lamolacrossfit/",
        "https://share.google/pTO0bMKcTnShi6oAO"
      ],
      "openingHoursSpecification": [
        {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday"],"opens":"07:00","closes":"21:30"},
        {"@type":"OpeningHoursSpecification","dayOfWeek":["Friday"],"opens":"07:00","closes":"20:30"},
        {"@type":"OpeningHoursSpecification","dayOfWeek":["Saturday","Sunday"],"opens":"09:30","closes":"11:30"}
      ],
      "areaServed": [
        {"@type":"City","name":"Terrassa"},
        {"@type":"City","name":"Sabadell"},
        {"@type":"City","name":"Sant Cugat del Vallès"},
        {"@type":"City","name":"Rubí"},
        {"@type":"City","name":"Matadepera"},
        {"@type":"City","name":"Viladecavalls"},
        {"@type":"City","name":"Sant Quirze del Vallès"},
        {"@type":"AdministrativeArea","name":"Vallès Occidental"}
      ]
    }
    </script>
    <script type="application/ld+json" data-schema="contactpage">
    {
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": "Contacta con CrossFit La Mola",
      "mainEntity": {"@id":"https://crossfitlamola.com/#organization"}
    }
    </script>
  </Fragment>

  <Nav currentPage="/es/contacte" />

  <section class="page-hero" id="main" style="min-height:50svh">
    <div class="bg" style="background-image:url('/assets/community-7.jpg')"></div>
    <div class="inner">
      <div class="crumb"><a href="/es">Inicio</a><span>/</span><span>Contacto</span></div>
      <div class="kicker"><span>Escríbenos</span><span class="bar"></span><span>Respuesta en 24h</span></div>
      <h1>Dinos<br><em class="serif">hola</em><span class="dot">.</span></h1>
      <p class="sub">Por WhatsApp es lo más rápido. Si prefieres vernos, pásate por el box: la puerta está abierta.</p>
    </div>
  </section>

  <section class="sec ink">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">01</span><span>Formulario</span></div>
      <div style="height:24px"></div>
      <div class="contact-grid">
        <form id="contact-form" class="reveal" style="display:grid; gap:28px;">
          <input type="text" name="website" style="position:absolute;left:-9999px;" tabindex="-1" autocomplete="off">
          <h2 class="h-xl">Reserva una<br>primera <em class="serif">clase</em><span class="dot">.</span></h2>
          <p style="font-family:var(--f-serif); font-size:18px; color:var(--bone-2); margin:0; max-width:44ch;">Déjanos tus datos y te respondemos con día y hora. Si ya sabes qué disciplina quieres probar, nos lo cuentas.</p>

          <div class="form-row two">
            <div class="field"><label for="c-name">Nombre y apellido</label><input id="c-name" type="text" name="name" required aria-required="true" placeholder="¿Cómo te llamas?"></div>
            <div class="field"><label for="c-phone">Teléfono</label><input id="c-phone" type="tel" name="phone" required aria-required="true" placeholder="629 ..."></div>
          </div>
          <div class="form-row two">
            <div class="field"><label for="c-email">Email</label><input id="c-email" type="email" name="email" required aria-required="true" placeholder="tu@correo.com"></div>
            <div class="field"><label for="c-disc">Disciplina que te interesa</label>
              <select id="c-disc" name="disc">
                <option>Todavía no lo sé</option><option>WOD</option><option>Weightlifting</option><option>Hybrid Club</option><option>Bodyweight Lab</option><option>Strength Club</option><option>The Program</option><option>Running Club</option>
              </select>
            </div>
          </div>
          <div class="form-row two">
            <div class="field"><label for="c-level">¿Has hecho CrossFit antes?</label>
              <select id="c-level" name="level"><option>Nunca</option><option>Alguna clase suelta</option><option>Sí, tengo experiencia</option><option>Compito</option></select>
            </div>
            <div class="field"><label for="c-when">¿Cuándo quieres venir?</label>
              <select id="c-when" name="when"><option>Esta semana</option><option>La semana que viene</option><option>Todavía no lo sé</option></select>
            </div>
          </div>
          <div class="field"><label for="c-note">¿Algo más que deberíamos saber?</label><textarea id="c-note" name="note" placeholder="Lesiones, objetivos, preguntas, dudas..."></textarea></div>
          <div style="display:flex; gap:20px; align-items:center; flex-wrap:wrap;">
            <button type="submit" class="form-submit" id="contact-submit">Enviar<span style="display:inline-block; width:20px; height:1px; background:currentColor;"></span></button>
            <span style="font-family:var(--f-mono); font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--muted);">o por WhatsApp al <a href="https://wa.me/34629066531" style="color:var(--accent-hi);">629 06 65 31</a></span>
          </div>
          <div id="contact-msg" style="display:none; padding:20px; border-radius:8px; font-family:var(--f-display);"></div>
        </form>

        <aside class="reveal">
          <h3 style="font-family:var(--f-display); font-weight:500; font-size:clamp(26px,2.8vw,36px); letter-spacing:-0.025em; margin:0 0 8px;">O encuéntranos<br>en cualquier <em class="serif">canal</em><span class="dot">.</span></h3>
          <div class="info-block">
            <div><div class="label">WhatsApp · Preferido</div><div class="value"><a href="https://wa.me/34629066531" style="display:inline-flex;align-items:center;gap:10px;"><svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>Escríbenos</a></div><div class="note">Respuesta en minutos, de lunes a sábado.</div></div>
            <div><div class="label">Llamada</div><div class="value"><a href="tel:+34629066531">629 06 65 31</a></div><div class="note">Para hablar directamente, de lunes a sábado.</div></div>
            <div><div class="label">Dirección</div><div class="value">Av. del Vallès 724C<br>08227 Terrassa · Barcelona</div><div class="note"><a href="https://share.google/Pme73HGLekvRLepee" target="_blank" rel="noopener" style="color:var(--accent-hi);">Cómo llegar &#8594;</a></div></div>
            <div><div class="label">Horario del box</div><div class="value" style="font-size:18px; line-height:1.5;">Lu–Ju · 07:00 – 21:30<br>Vi · 07:00 – 20:30<br>Sa–Do · 09:30 – 11:30</div></div>
            <div><div class="label">Redes</div><div class="value"><a href="https://www.instagram.com/lamolacrossfit/" target="_blank" rel="noopener">@lamolacrossfit</a></div><div class="note">El día a día, fotos y la comunidad.</div></div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="sec bone">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">02</span><span>Dónde estamos</span></div>
      <div style="height:16px"></div>
      <h2 class="h-xl reveal">A dos minutos<br>de la <em class="serif">salida</em><span class="dot">.</span></h2>
      <p class="lead reveal" style="margin-top:22px;">En la Av. del Vallès 724C, bien comunicado por la B-40 y C-58. Zona de parking gratuito y espacio para bicicletas y patinetes.</p>

      <div class="visit-bar reveal-stagger">
        <div style="--i:0"><h4>01 · En coche</h4><p>Acceso directo desde la <em>B-40</em> o <em>C-58</em>. Zona de parking gratuito delante del box.</p></div>
        <div style="--i:1"><h4>02 · Transporte público</h4><p>FGC · <em>Estació del Nord</em> a 8 min andando. Varias líneas de bus cercanas.</p></div>
        <div style="--i:2"><h4>03 · Bici o patinete</h4><p>Bien comunicado por carril bici. <em>Espacio cubierto</em> para aparcar bicicletas y patinetes dentro del box.</p></div>
      </div>

      <div class="map reveal">
        <iframe src="https://www.openstreetmap.org/export/embed.html?bbox=2.0229%2C41.5782%2C2.0329%2C41.5842&amp;layer=mapnik&amp;marker=41.581285%2C2.027955" loading="lazy" title="Mapa de CrossFit La Mola"></iframe>
      </div>
    </div>
  </section>

  <Footer />

<script>
  const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwHm_4Rwt_x9RN5q1PEKxTzXj587hgKYp70WqyNA9DpbETdy-dcUPt2n3YtaZ7KFJinww/exec';

  function getSource() {
    const params = new URLSearchParams(window.location.search);
    const utm = params.get('utm_source');
    if (utm) return utm;
    const from = params.get('from');
    if (from) return from;
    return 'web';
  }

  document.getElementById('contact-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = document.getElementById('contact-submit');
    const msg = document.getElementById('contact-msg');
    const btnText = btn.innerHTML;

    btn.innerHTML = 'Enviando...';
    btn.disabled = true;
    msg.style.display = 'none';

    const source = getSource();
    const data = {
      origen: 'Contacto ES (' + source + ')',
      name: form.name.value,
      email: form.email.value,
      phone: form.phone.value,
      disc: form.disc.value,
      level: form.level.value,
      when: form.when.value,
      note: form.note.value,
      website: form.website.value
    };

    try {
      await fetch(SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      msg.style.display = 'block';
      msg.style.background = 'var(--accent-ink)';
      msg.style.color = 'var(--bone)';
      msg.innerHTML = '<strong>¡Gracias!</strong> Hemos recibido tu mensaje. Te contactamos pronto.';
      form.reset();

      if (typeof gtag !== 'undefined') {
        gtag('event', 'generate_lead', {
          event_category: 'forms',
          event_label: 'Contacto ES',
          value: 1
        });
      }
    } catch (err) {
      msg.style.display = 'block';
      msg.style.background = '#fee';
      msg.style.color = '#c00';
      msg.innerHTML = 'Error al enviar. Prueba por WhatsApp: <a href="https://wa.me/34629066531" style="color:#c00;">629 06 65 31</a>';
    }

    btn.innerHTML = btnText;
    btn.disabled = false;
  });
</script>
</Layout>
