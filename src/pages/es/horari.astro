    function classify(name){
      var n=name.toUpperCase();
      if (n==='OPEN' || n==='OPEN EXTERIOR') return {k:'open', l:n, interior:n==='OPEN'};
      if (n==='ENTRENA CON TU COACH') return {k:'etc', l:'Entrena con tu coach'};
      if (n.indexOf('THE PROGRAM')>=0) return {k:'pr', l:'The Program'};
      if (n.indexOf('WEIGHTLIFTING')>=0) return {k:'wl', l:'Weightlifting'};
      if (n.indexOf('HYBRID')>=0) return {k:'hy', l:'Hybrid Club'};
      if (n.indexOf('STRENGTH')>=0) return {k:'st', l:'Strength · Powerlifting'};
      if (n.indexOf('BODYWEIGHT')>=0) return {k:'bw', l:n.indexOf('ADVANCE')>=0?'Bodyweight Lab · Advance':'Bodyweight Lab · Base'};
      if (n.indexOf('ABS')>=0) return {k:'ab', l:'Abs & Cals'};
      if (n.indexOf('RUNNING')>=0 || n.indexOf('RUN BY')>=0) return {k:'rc', l:n.indexOf('BEACH')>=0?'Run + Brunch + Beach':'Running Club'};
      if (n.indexOf('WOD IN PAIRS')>=0) return {k:'wod', l:'WOD en Parejas'};
      if (n.indexOf('WOD')>=0) return {k:'wod', l: n.indexOf('INICIACI')>=0?'WOD · Iniciación':'WOD'};
      return {k:'wod', l:name};
    }

    var days=['Lunes','Martes','Miércoles','Jueves','Viernes','Sábado','Domingo'];
    var abbr=['Lu','Ma','Mi','Ju','Vi','Sa','Do'];
    var monday=new Date(); var day=monday.getDay(); var diff=(day===0?-6:1-day); monday.setDate(monday.getDate()+diff);
    var today=new Date(); today.setHours(0,0,0,0);
    var fmt=function(d){ return d.getDate()+' '+['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'][d.getMonth()];};
    document.querySelectorAll('.js-week-range').forEach(function(el){ var s=new Date(monday); var e=new Date(monday); e.setDate(e.getDate()+6); el.textContent = fmt(s)+' - '+fmt(e); });

    var counts={all:0,wod:0,wl:0,hy:0,bw:0,st:0,ab:0,pr:0,rc:0,etc:0};
    var week=document.getElementById('week');

    if (week) {
      days.forEach(function(dname, i){
        var d=new Date(monday); d.setDate(d.getDate()+i);
        var isToday=(d.getTime()===today.getTime());
        var div=document.createElement('div'); div.className='day'+(isToday?' today':'');
        div.innerHTML='<h4><span class="full">'+dname+'</span><span class="abbrev">'+abbr[i]+'</span></h4>';

        var slots=SCHEDULE[dname]||[];
        var dayHasCoached = slots.some(function(entry){
          return entry[1].some(function(c){ return classify(c).k !== 'open'; });
        });
        if (!slots.length){
          div.innerHTML += '<p class="empty">Descanso · sin clases</p>';
        } else {
          slots.forEach(function(entry){
            var time=entry[0], arr=entry[1];
            var coached=[], opens=[];
            arr.forEach(function(c){ var r=classify(c); if(r.k==='open') opens.push(r); else coached.push(r); });

            if (!coached.length && !opens.length) return;

            if (coached.length){
              coached.forEach(function(r){
                counts.all++; if(counts[r.k]!==undefined) counts[r.k]++;
                var extras='';
                if (opens.length) extras='+ Open'+(opens.some(function(o){return !o.interior;})?' · Exterior':'');
                var el=document.createElement('div');
                el.className='slot';
                el.setAttribute('data-disc', r.k);
                el.innerHTML='<div class="time">'+time+'</div><div class="disc">'+r.l+'</div>'+(extras?'<div class="extras">'+extras+'</div>':'');
                div.appendChild(el);
              });
            } else if (opens.length){
              var label=opens.map(function(o){return o.l==='OPEN EXTERIOR'?'Open Exterior':'Open';}).join(' - ');
              var el=document.createElement('div');
              el.className='slot open-only' + (dayHasCoached ? '' : ' always-visible');
              el.setAttribute('data-disc', 'open');
              el.innerHTML='<div class="time">'+time+'</div><div class="disc">'+label+'</div>';
              div.appendChild(el);
            }
          });
        }
        week.appendChild(div);
      });
    }

    Object.keys(counts).forEach(function(k){ var el=document.getElementById('c-'+k); if(el) el.textContent='· '+counts[k]; });

    var currentFilter='all';
    var filtersEl = document.getElementById('filters');
    if (filtersEl) {
      filtersEl.addEventListener('click', function(e){
        var b=e.target.closest('.filter'); if(!b) return;
        document.querySelectorAll('.filter').forEach(function(x){x.classList.remove('on');});
        b.classList.add('on');
        currentFilter=b.dataset.f;
        applyFilter();
      });
    }

    var showOpen=false;
    var showOpenEl = document.getElementById('showOpen');
    if (showOpenEl) {
      showOpenEl.addEventListener('change', function(e){
        showOpen=e.target.checked;
        applyFilter();
      });
    }

    function applyFilter(){
      document.querySelectorAll('.slot').forEach(function(s){
        var d=s.dataset.disc;
        var isOpen=(d==='open');
        var alwaysVisible=s.classList.contains('always-visible');
        var matchFilter = (currentFilter==='all') || (d===currentFilter);
        var visible = matchFilter && (!isOpen || showOpen || alwaysVisible);
        s.classList.toggle('hidden', !visible);
      });
    }
    applyFilter();
  })();
  </script>
</Layout>
