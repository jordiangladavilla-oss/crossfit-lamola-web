---
import Layout from '../../layouts/Layout.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import Schema from '../../components/Schema.astro'
import { agendaEvents, formatEventDays, getEventMonthShort, getEventName, getEventPlace } from '../../data/agenda'

// Transformamos los eventos para el formato de la sección agenda del index
const AGENDA = agendaEvents.slice(0, 6).map(e => {
  const placeParts = getEventPlace(e, 'es').split(' · ')
  return {
    d: formatEventDays(e),
    m: getEventMonthShort(e, 'es'),
    title: getEventName(e, 'es'),
    cat: e.cat === 'comp-ext' ? 'competicio' : e.cat,
    meta: placeParts,
    tag: e.featured || false,
    note: ''
  }
})
---

<Layout
  title="CrossFit La Mola | Box CrossFit Terrassa - Entrenamiento Funcional"
  description="Box de CrossFit en Terrassa. Entrenamiento funcional para todos los niveles con coaches certificados. Primera clase gratuita."
  canonical="https://crossfitlamola.com/es"
  bodyData={{ "data-hero": "full" }}
>
  <Schema type="home" slot="head" />
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Puedo hacer CrossFit si no estoy en forma?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. De hecho, es por donde todo el mundo empieza. Cada movimiento tiene versiones más sencillas y un coach te acompaña desde el primer día hasta que tu cuerpo se siente cómodo."
          }
        },
        {
          "@type": "Question",
          "name": "¿Mi cuerpo se musculará muy rápido?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Ponerse muy musculado es un proyecto mucho más largo y específico que venir tres días por semana. Lo que encontrarás es forma, postura y un cuerpo que aguanta el día a día."
          }
        },
        {
          "@type": "Question",
          "name": "¿Me haré daño haciendo CrossFit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Si haces bien las cosas, no. Programamos para progresar, no para romper. Los pesos son los tuyos, la técnica va primero, y los coaches corrigen en tiempo real."
          }
        },
        {
          "@type": "Question",
          "name": "¿Y si no conozco a nadie en el box?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Es el caso más habitual. Al cabo de dos semanas hay nombres y caras que ya te reconocen. En comunidad esto pasa sin esfuerzo."
          }
        },
        {
          "@type": "Question",
          "name": "¿Puedo hacer CrossFit si soy mayor?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "En la comunidad hay personas de 19 años y de más de 60. La edad no es una cualidad, es una variable. Escalamos la programación a tu nivel, siempre."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué incluye la primera clase gratuita?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Una hora con un coach que te hace una breve valoración, te explica el movimiento del día, y te pone a entrenar con el resto del grupo. Nada más. Sin compromiso después."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta CrossFit La Mola y qué incluye cada plan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hay cuotas mensuales según días por semana, y bonos de 10 clases. Sin permanencia. Te lo explicamos tranquilamente después de la primera clase, o escríbenos por WhatsApp y lo hablamos."
          }
        }
      ]
    }
    </script>
  </Fragment>

  <Nav currentPage="/" lang="es" />

  <main id="main">
  <section class="hero" id="top">
    <div class="hero-grid">
      <div class="hero-media">
        <video autoplay muted loop playsinline preload="metadata" poster="/assets/hero-still.webp">
          <source src="/assets/hero.mp4" type="video/mp4">
        </video>
      </div>

      <div class="hero-copy">
        <div>
          <div class="hero-kicker">
            <span>Move with purpose</span>
            <span class="bar"></span>
            <span>Terrassa · CrossFit Affiliate</span>
          </div>
          <h1 class="visually-hidden">CrossFit La Mola · Box de CrossFit en Terrassa.</h1>
          <img class="hero-logo" src="/assets/logo-full.png" alt="CrossFit La Mola. Build strength together.">
        </div>

        <div class="hero-bottom-row">
          <p class="hero-sub">
            3 coaches. 9 disciplinas. Un espacio.<br>
            Tú pones el esfuerzo, el tiempo hace el resto.
          </p>
          <a class="hero-cta" href="/es/contacte">
            Reserva tu clase de prueba
            <span class="arr"></span>
          </a>
        </div>

        <div class="hero-meta">
          <span><span class="k">CrossFit</span> <span class="v">Affiliate</span></span>
          <span><span class="k">Atletas</span> <span class="v">+250</span></span>
          <span><span class="k">Coaches</span> <span class="v">03</span></span>
          <span><span class="k">Horas/semana</span> <span class="v">+60h</span></span>
        </div>
      </div>
    </div>
  </section>

  <div class="status-strip">
    <span class="live" id="live-status">Clase en curso · Consulta el horario</span>
    <span>Lu–Ju 07:00–21:30 · Vi 07:00–20:30 · Sá–Do 09:30–11:30</span>
    <span>Av. del Vallès 724C · 08227 Terrassa</span>
  </div>

  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span>
        WOD <em>·</em> Weightlifting <span class="sep"></span>
        Hybrid Club <em>·</em> Bodyweight Lab <span class="sep"></span>
        Strength Club <em>·</em> Abs &amp; Cals <span class="sep"></span>
        The Program <em>·</em> Entrena con tu Coach <span class="sep"></span>
        Running Club <em>·</em>
      </span>
      <span>
        WOD <em>·</em> Weightlifting <span class="sep"></span>
        Hybrid Club <em>·</em> Bodyweight Lab <span class="sep"></span>
        Strength Club <em>·</em> Abs &amp; Cals <span class="sep"></span>
        The Program <em>·</em> Entrena con tu Coach <span class="sep"></span>
        Running Club <em>·</em>
      </span>
    </div>
  </div>

  <section class="sec bone" id="manifest">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">01</span><span>Move with purpose</span></div>
      <div style="height: 32px"></div>
      <div class="manifest">
        <h2 class="h-xl reveal">
          Cada día <em class="serif">igual</em><span class="dot">.</span><br>El ritual se repite.
        </h2>
        <div class="manifest-body reveal">
          <p>La puerta se abre y, con el primer contacto de las barras con el suelo, se inicia un proceso que se repite y evoluciona con cada sesión: no es solo mover peso, sino construir una base sólida con constancia. Con el tiempo, la fuerza se consolida y la confianza crece a medida que entiendes tu cuerpo y lo que es capaz de hacer.</p>
          <p class="sig">Sergi · Juse · Eli</p>
        </div>
      </div>
    </div>
  </section>

  <section class="sec bone" id="story" style="padding-top: 0;">
    <div class="inner">
      <div style="border-top: 1px solid var(--line-ink); padding-top: clamp(60px, 8vw, 100px)"></div>
      <div class="story-grid">
        <div class="story-copy reveal">
          <div class="eyebrow"><span class="num">02</span><span>Respect the craft</span></div>
          <h2 class="h-xl">El nombre viene de una<br><em class="serif">montaña</em><span class="dot">.</span></h2>
          <p>La Mola corona Terrassa y representa una manera de entender el esfuerzo: avanzar paso a paso, aceptando el desnivel y manteniendo un ritmo constante. Esta misma lógica define la manera de entrenar en el box: no se trata de llegar al punto más alto en un solo día, sino de volver semana tras semana y darte cuenta de que, casi sin hacer ruido, ya estás un poco más arriba que antes.</p>
          <a href="/es/el-box" class="story-link">Ver todo el box <span class="arr"></span></a>
        </div>
        <div class="story-images reveal-stagger">
          <figure class="tall" style="--i:0"><img src="/assets/lamola-climb.jpg" alt="Atleta haciendo rope climb en CrossFit La Mola, como subir La Mola paso a paso" loading="lazy"></figure>
          <figure style="--i:1"><img src="/assets/detail-chalk.webp" alt="Mano de atleta con magnesio preparándose para levantar" loading="lazy"></figure>
          <figure style="--i:2"><img src="/assets/detail-dumbbells.webp" alt="Rack de mancuernas de competición en el box" loading="lazy"></figure>
          <figure style="--i:3"><img src="/assets/class-weightlifting.webp" alt="Atleta haciendo halterofilia con barra sobre la cabeza en el box" loading="lazy"></figure>
          <figure style="--i:4"><img src="/assets/detail-rope.webp" alt="Cuerda de batalla enrollada en el suelo del box" loading="lazy"></figure>
        </div>
      </div>
    </div>
  </section>

  <section class="sec bone" id="disciplines" style="padding-top: clamp(60px, 8vw, 120px)">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">03</span><span>Leave no one behind</span></div>
      <div style="height: 24px"></div>
      <div class="disc-head">
        <h2 class="h-xl reveal">9 disciplinas.<br><em class="serif">Una filosofía</em><span class="dot">.</span></h2>
        <p class="reveal">El centro es el WOD, donde se combinan la halterofilia, la gimnástica y el trabajo híbrido para desarrollar un rendimiento completo. A partir de aquí, cada disciplina se trabaja también de manera específica para consolidar la técnica y la progresión, con el powerlifting y las sesiones de Abs & Cals como base que sostiene todo el conjunto.</p>
      </div>
      <div class="disc-grid reveal-stagger">
        <a href="/es/classes" class="disc-card" style="--i:0">
          <div class="img"><img src="/assets/class-wod.webp" alt="Clase WOD en CrossFit La Mola con grupo de atletas y coach explicando el workout" loading="lazy"></div>
          <div class="body">
            <div class="tag">Cada día · Base</div>
            <h3>WOD</h3>
            <p>La esencia del CrossFit. Calentamiento, fuerza o skill, y un METCON que cambia cada día. Cinco días por semana, más un WOD in pairs los sábados.</p>
            <span class="link">Ver clase →</span>
          </div>
        </a>
        <a href="/es/classes" class="disc-card" style="--i:1">
          <div class="img"><img src="/assets/class-weightlifting.webp" alt="Atleta haciendo jerk con barra olímpica durante clase de Weightlifting" loading="lazy"></div>
          <div class="body">
            <div class="tag">Halterofilia · Técnica</div>
            <h3>Weightlifting</h3>
            <p>Snatch, clean y jerk. Los tres movimientos estrella exigen detalle y paciencia. Buscamos levantar mejor. Levantar pesado viene después.</p>
            <span class="link">Ver clase →</span>
          </div>
        </a>
        <a href="/es/classes" class="disc-card" style="--i:2">
          <div class="img"><img src="/assets/class-hybrid.webp" alt="Atletas entrenando en la Concept2 BikeERG durante clase Hybrid Club" loading="lazy"></div>
          <div class="body">
            <div class="tag">Fuerza + Resistencia</div>
            <h3>Hybrid Club</h3>
            <p>Entrenar fuerte sin la barrera técnica. Fuerza y resistencia combinadas con movimientos simples, sin halterofilia ni gimnástico complejo.</p>
            <span class="link">Ver clase →</span>
          </div>
        </a>
        <a href="/es/classes" class="disc-card" style="--i:3">
          <div class="img"><img src="/assets/class-bodyweight.webp" alt="Atletas haciendo rope climb durante clase de Bodyweight Lab" loading="lazy"></div>
          <div class="body">
            <div class="tag">Gimnástico · Base / Advance</div>
            <h3>Bodyweight Lab</h3>
            <p>Controlamos el cuerpo desglosando los movimientos gimnásticos. Base para quien empieza; Advance para el butterfly, BMU, HSW y HSPU.</p>
            <span class="link">Ver clase →</span>
          </div>
        </a>
        <a href="/es/classes" class="disc-card" style="--i:4">
          <div class="img"><img src="/assets/class-strength.webp" alt="Grupo de atletas con barras olímpicas durante clase Strength Club" loading="lazy"></div>
          <div class="body">
            <div class="tag">Fuerza pura · 2 días/semana</div>
            <h3>Strength Club</h3>
            <p>Dos días por semana dedicados a la fuerza. Sentadilla, peso muerto y press, con variantes para reforzar estabilidad y core.</p>
            <span class="link">Ver clase →</span>
          </div>
        </a>
        <a href="/es/classes" class="disc-card" style="--i:5">
          <div class="img"><img src="/assets/class-abs.webp" alt="Atleta entrenando en la rower Concept2 durante clase Abs and Cals" style="object-position: center top;" loading="lazy"></div>
          <div class="body">
            <div class="tag">Máquinas · Core</div>
            <h3>Abs &amp; Cals</h3>
            <p>Row, ski erg, bike erg y echo bike, combinados con trabajo específico de core. Estructura pensada para mejorar tu rendimiento en el WOD.</p>
            <span class="link">Ver clase →</span>
          </div>
        </a>
        <a href="/es/classes" class="disc-card" style="--i:6">
          <div class="img"><img src="/assets/class-program.webp" alt="Coach explicando el WOD en la pizarra con atletas escuchando" loading="lazy"></div>
          <div class="body">
            <div class="tag">Competición · RX · Ciclos</div>
            <h3>The Program</h3>
            <p>Para quien quiere competir. Tres sesiones semanales siguiendo programación RX, estructuradas en ciclos que permiten progresar de forma sólida y consistente.</p>
            <span class="link">Ver clase →</span>
          </div>
        </a>
        <a href="/es/classes" class="disc-card" style="--i:7">
          <div class="img"><img src="/assets/class-coach.webp" alt="Coach con camiseta La Mola supervisando entrenamiento de atletas" loading="lazy"></div>
          <div class="body">
            <div class="tag">90 min · Programación compartida</div>
            <h3>Entrena con tu Coach</h3>
            <p>Tres días a la semana entrenamos 90 minutos junto a uno de los coaches. No es una clase dirigida: sigues la misma pizarra y adaptas los movimientos a tu nivel.</p>
            <span class="link">Ver clase →</span>
          </div>
        </a>
        <a href="/es/classes" class="disc-card" style="--i:8">
          <div class="img"><img src="/assets/class-running.webp" alt="Dos atletas sonriendo mientras entrenan en las Echo Bikes" loading="lazy"></div>
          <div class="body">
            <div class="tag">Correr · En comunidad</div>
            <h3>Running Club</h3>
            <p>Para sumar el correr a tu entrenamiento, y hacerlo en comunidad. Un espacio para compartir la carrera con otros atletas.</p>
            <span class="link">Ver clase →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="sec ink" id="coaches">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">04</span><span>100 fades · Strength stays</span></div>
      <div style="height: 24px"></div>
      <div class="coaches-head">
        <h2 class="h-xl reveal">3 personas.<br>Una manera<br>de entender <em class="serif">el movimiento</em><span class="dot">.</span></h2>
        <p class="reveal">Tres personas, una misma manera de entender el movimiento. Programan con criterio y corrigen con precisión para acompañarte como es debido en cada etapa del proceso.</p>
      </div>
      <div class="coaches-grid reveal-stagger">
        <article class="coach" style="--i:0">
          <div class="photo">
            <span class="tag">01 · Head Coach</span>
            <img src="/assets/coach-sergi.jpg" alt="Sergi, head coach y cofundador de CrossFit La Mola, certificado CF-L2" loading="lazy">
          </div>
          <h3>Sergi</h3>
          <div class="coach-kvs">
            <span class="k">In love with</span> <span class="v">Squat snatch</span>
            <span class="k">Kriptonita</span> <span class="v">Wall climbs</span>
            <span class="k">Work in progress</span> <span class="v">Free handstand push-up</span>
          </div>
          <p class="coach-quote">"Ser coach es enseñar, pero sobre todo aprender. El CrossFit es el pilar de mi día: fuerza mental y física en una hora."</p>
        </article>
        <article class="coach" style="--i:1">
          <div class="photo">
            <span class="tag">02 · Coach</span>
            <img src="/assets/coach-juse.jpg" alt="Juse, coach de CrossFit La Mola, certificado CF-L1" loading="lazy">
          </div>
          <h3>Juse</h3>
          <div class="coach-kvs">
            <span class="k">In love with</span> <span class="v">Squat clean</span>
            <span class="k">Kriptonita</span> <span class="v">Strict HSPU</span>
            <span class="k">Work in progress</span> <span class="v">HSW ramp</span>
          </div>
          <p class="coach-quote">"El snatch y el clean no son trucos, sino el resultado de horas de práctica y atención al detalle. Ven con paciencia: lo que buscas ya lo llevas dentro, y se construye a base de constancia, afinándolo día tras día."</p>
        </article>
        <article class="coach" style="--i:2">
          <div class="photo">
            <span class="tag">03 · Coach</span>
            <img src="/assets/coach-eli.jpg" alt="Eli, coach y cofundadora de CrossFit La Mola, certificada CF-L1" loading="lazy">
          </div>
          <h3>Eli</h3>
          <div class="coach-kvs">
            <span class="k">In love with</span> <span class="v">Wall climbs</span>
            <span class="k">Kriptonita</span> <span class="v">HSPU</span>
            <span class="k">Work in progress</span> <span class="v">Snatch</span>
          </div>
          <p class="coach-quote">"Para mí, CrossFit es paz mental. Reconectar, valorar el cuerpo. Técnica antes que peso. El progreso nunca es lineal."</p>
        </article>
      </div>
    </div>
  </section>

  <section class="sec bone" id="agenda">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">05</span><span>Support · Encourage</span></div>
      <div style="height: 24px"></div>
      <div class="schedule-head">
        <h2 class="h-xl reveal">Más que<br><em class="serif">entrenamiento</em><span class="dot">.</span></h2>
        <p class="reveal">Fuera del box pasan cosas. Salidas a la montaña. WODs en la playa, competiciones, fiestas. La comunidad es lo que sostiene este box y lo hace crecer más allá de cada sesión. Estas son las próximas citas.</p>
      </div>
      <div class="schedule-strip" id="filter-strip">
        <button class="chip is-active" data-filter="all">Todo</button>
        <button class="chip" data-filter="activitat">Actividades</button>
        <button class="chip" data-filter="competicio">Competiciones</button>
      </div>
      <div class="agenda" id="agenda-list" aria-live="polite">
        {AGENDA.map(item => (
          <div class={`agenda-row ${item.tag ? 'tag' : ''}`} data-cat={item.cat}>
            <div class="date">{item.d}<span class="m">{item.m}</span></div>
            <div class="title">{item.title}</div>
            <div class="meta">{item.meta.map((m, i) => <><span>{m}</span>{i < item.meta.length - 1 && <span class="sep">·</span>}</>)}</div>
            <div class="note">{item.note}</div>
          </div>
        ))}
      </div>
      <div class="agenda-foot">
        <span>Fuente propia</span>
        <a href="/es/agenda">Ver agenda completa →</a>
      </div>
    </div>
  </section>

  <section class="sec ink" id="comunitat">
    <div class="inner">
      <div class="eyebrow reveal"><span class="num">06</span><span>You show up · We stay</span></div>
      <div style="height: 24px"></div>
      <div class="comm-head">
        <h2 class="h-xl reveal">La gente <em class="serif">que hace</em> el box<span class="dot">.</span></h2>
        <p class="reveal">Algunas personas buscan salud, otras rendimiento o competición. También hay quienes vienen para desconectar, socializar o encontrar un espacio donde sentirse cómodos y seguros. Aquí todo el mundo escala, todo el mundo progresa y todo el mundo tiene su espacio.</p>
      </div>
      <div class="comm-grid reveal-stagger">
        <figure class="wide" style="--i:0"><img src="/assets/RAQ_7644.jpg" alt="El equipo completo de CrossFit La Mola: coaches y atletas juntos en el box" loading="lazy"></figure>
        <figure style="--i:2"><img src="/assets/detail-chalk.webp" alt="Mano de atleta con magnesio preparándose para levantar" loading="lazy"></figure>
        <div class="quote-card" style="--i:3">
          <blockquote>"Muy buen ambiente, grandes profesionales, familiar y con muy buenas instalaciones."</blockquote>
          <cite>Marc · diciembre 2025 · <a href="https://goo.gl/maps/v5yuvhn1jXABGmbY8?g_st=aw" target="_blank" rel="noopener">Ver reseña</a></cite>
        </div>
        <figure class="tall" style="--i:4"><img src="/assets/community-7.webp" alt="Grupo de atletas animando a un compañero durante el WOD" loading="lazy"></figure>
        <figure style="--i:5"><img src="/assets/community-4.webp" alt="Dos atletas sonriendo mientras entrenan en las Echo Bikes" loading="lazy"></figure>
        <figure style="--i:6"><img src="/assets/community-6.webp" alt="Atletas entrenando juntos en clase de CrossFit" loading="lazy"></figure>
        <div class="quote-card" style="--i:7">
          <blockquote>"Sin duda el mejor box donde he estado. Son muy cercanos, atentos, siempre están pendientes de ti. Todo está ordenado, limpio e impecable. Además, no paran de innovar y mejorar. ¡Un gusto entrenar aquí!"</blockquote>
          <cite>Eva · abril 2025 · <a href="https://goo.gl/maps/HP3B6uTDn8vEuixR6?g_st=aw" target="_blank" rel="noopener">Ver reseña</a></cite>
        </div>
        <figure style="--i:8"><img src="/assets/community-4.2.webp" alt="Tres atletas celebrando después de un entrenamiento intenso" loading="lazy"></figure>
        <figure class="wide" style="--i:9"><img src="/assets/community-group.webp" alt="Grupo amplio de atletas posando juntos en el box" loading="lazy"></figure>
        <figure class="tall" style="--i:10"><img src="/assets/community-8.webp" alt="Atleta haciendo ring muscle-ups durante el WOD" loading="lazy"></figure>
      </div>
    </div>
  </section>

  <section class="sec bone" id="faq">
    <div class="inner">
      <div class="faq-head">
        <div class="eyebrow reveal"><span class="num">07</span><span>Preguntas frecuentes</span></div>
        <h2 class="h-xl reveal">Todo lo que necesitas <em class="serif">saber</em><span class="dot">.</span></h2>
      </div>
      <div class="faq reveal">
        <details>
          <summary>¿Puedo hacer CrossFit si no estoy en forma?<span class="sign"></span></summary>
          <p class="a">Sí. De hecho, es por donde todo el mundo empieza. Cada movimiento tiene versiones más sencillas y un coach te acompaña desde el primer día hasta que tu cuerpo se siente cómodo.</p>
        </details>
        <details>
          <summary>¿Mi cuerpo se musculará muy rápido?<span class="sign"></span></summary>
          <p class="a">No. Ponerse "muy musculado" es un proyecto mucho más largo y específico que venir tres días por semana. Lo que encontrarás es forma, postura y un cuerpo que aguanta el día a día.</p>
        </details>
        <details>
