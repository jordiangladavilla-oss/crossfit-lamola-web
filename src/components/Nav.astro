---
interface Props {
  currentPage?: string
}

const { currentPage = '' } = Astro.props

const links = [
  { href: '/classes', label: 'Classes' },
  { href: '/horari', label: 'Horari' },
  { href: '/tarifes', label: 'Tarifes' },
  { href: '/el-box', label: 'El box' },
  { href: '/agenda', label: 'Agenda' },
  { href: '/contacte', label: 'Contacte' },
]
---

<nav class="nav" id="nav">
  <a href="/" class="mark" aria-label="CrossFit La Mola">
    <img src="/assets/logo-short.png" alt="La Mola.">
  </a>
  <ul>
    {links.map(link => (
      <li>
        <a href={link.href} class:list={[{ 'is-active': currentPage === link.href }]}>
          {link.label}
        </a>
      </li>
    ))}
  </ul>
  <a href="/contacte" class="cta-mini">Primera classe gratuïta</a>
  <button class="nav-toggle" id="nav-toggle" aria-label="Menú">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<div class="nav-mobile" id="mobile-nav">
  {links.map(link => (
    <a href={link.href}>{link.label}</a>
  ))}
  <a href="/contacte" class="cta-mini" style="margin-top: 20px;">Primera classe gratuïta</a>
</div>
