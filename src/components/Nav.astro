---
import LanguageSwitcher from './LanguageSwitcher.astro'
import { getLangFromUrl, useTranslations } from '../i18n/utils'

interface Props {
  currentPage?: string
}

const { currentPage = '' } = Astro.props

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const prefix = lang === 'ca' ? '' : `/${lang}`

const links = [
  { href: `${prefix}/classes`, label: t('nav.classes') },
  { href: `${prefix}/horari`, label: t('nav.horari') },
  { href: `${prefix}/tarifes`, label: t('nav.tarifes') },
  { href: `${prefix}/el-box`, label: t('nav.elbox') },
  { href: `${prefix}/agenda`, label: t('nav.agenda') },
  { href: `${prefix}/contacte`, label: t('nav.contacte') },
]

const homeHref = prefix || '/'
---

<nav class="nav" id="nav">
  <a href={homeHref} class="mark" aria-label="CrossFit La Mola">
    <img src="/assets/logo-short.png" alt="La Mola.">
  </a>
  <ul>
    {links.map(link => (
      <li>
        <a href={link.href} class:list={[{ 'is-active': currentPage === link.href }]}>
          {link.label}
        </a>
      </li>
    ))}
  </ul>
  <div class="nav-right">
    <LanguageSwitcher />
    <a href={`${prefix}/contacte`} class="cta-mini">{t('nav.cta')}</a>
  </div>
  <button class="nav-toggle" id="nav-toggle" aria-label="Menú">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<div class="nav-mobile" id="mobile-nav">
  {links.map(link => (
    <a href={link.href}>{link.label}</a>
  ))}
  <LanguageSwitcher />
  <a href={`${prefix}/contacte`} class="cta-mini" style="margin-top: 20px;">{t('nav.cta')}</a>
</div>
