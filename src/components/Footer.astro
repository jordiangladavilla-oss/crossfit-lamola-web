---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const prefix = lang === 'ca' ? '' : `/${lang}`

const currentYear = new Date().getFullYear()

const langLabel = { ca: 'Català', es: 'Español', en: 'English' }[lang]
---

<footer>
  <div class="foot-top">
    <div>
      <div class="foot-mark">
        <img src="/assets/logo-full.png" alt="CrossFit La Mola. Build strength together">
      </div>
    </div>
    <div class="foot-col">
      <h5>{t('footer.nav')}</h5>
      <a href={`${prefix}/classes`}>{t('nav.classes')}</a>
      <a href={`${prefix}/horari`}>{t('nav.horari')}</a>
      <a href={`${prefix}/tarifes`}>{t('nav.tarifes')}</a>
      <a href={`${prefix}/el-box`}>{t('nav.elbox')}</a>
      <a href={`${prefix}/agenda`}>{t('nav.agenda')}</a>
      <a href={`${prefix}/contacte`}>{t('nav.contacte')}</a>
    </div>
    <div class="foot-col">
      <h5>{t('footer.location')}</h5>
      <p>Av. del Vallès 724C</p>
      <p>08227 Terrassa · Barcelona</p>
      <a href="https://maps.app.goo.gl/LMWX4XfiVLq8PXxAA" target="_blank" rel="noopener">{t('footer.directions')} →</a>
    </div>
    <div class="foot-col">
      <h5>{t('nav.contacte')}</h5>
      <a href="https://wa.me/34629066531">629 06 65 31</a>
      <a href="https://www.instagram.com/lamolacrossfit/" target="_blank" rel="noopener">@lamolacrossfit</a>
    </div>
  </div>
  <div class="foot-bottom">
    <span>© {currentYear} CrossFit La Mola.</span>
    <span><a href={`${prefix}/avis-legal`}>{t('footer.legal')}</a> · <a href={`${prefix}/privacitat`}>{t('footer.privacy')}</a> · <a href={`${prefix}/cookies`}>{t('footer.cookies')}</a></span>
    <span>{t('footer.madein')} · {langLabel}</span>
  </div>
</footer>
