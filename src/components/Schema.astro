const homeExtras = {
  "@context": "https://schema.org",
  "@type": "ExerciseGym",
  "@id": "https://crossfitlamola.com/#organization-team",
  "employee": [
    {"@type":"Person","name":"Sergi","jobTitle":"Head Coach & Co-fundador","hasCredential":{"@type":"EducationalOccupationalCredential","credentialCategory":"CrossFit Level 2 Trainer (CF-L2)"}},
    {"@type":"Person","name":"Eli","jobTitle":"Coach & Co-fundadora","hasCredential":{"@type":"EducationalOccupationalCredential","credentialCategory":"CrossFit Level 1 Trainer (CF-L1)"}},
    {"@type":"Person","name":"Juse","jobTitle":"Coach","hasCredential":{"@type":"EducationalOccupationalCredential","credentialCategory":"CrossFit Level 1 Trainer (CF-L1)"}}
  ],
  "amenityFeature": [
